<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BHServe.App.Views.PythonPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BHServe.App.Views">

    <ScrollViewer>
    <StackPanel Padding="24" Spacing="16">
        <StackPanel Spacing="2">
            <TextBlock Text="Python" FontSize="26" FontWeight="SemiBold"/>
            <TextBlock Opacity="0.7" Text="A managed Python interpreter + supervised Python-app sites (Flask / Django / FastAPI / Gunicorn / Uvicorn)"/>
        </StackPanel>

        <TextBlock Text="Interpreter" FontSize="16" FontWeight="SemiBold"/>
        <Border BorderThickness="1" CornerRadius="8" Padding="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock x:Name="InterpStatus" VerticalAlignment="Center" Text="checking…"/>
                <Button x:Name="InstallPyBtn" Content="Install Python" Click="InstallPy_Click" Style="{StaticResource AccentButtonStyle}"/>
                <ProgressRing x:Name="Busy" IsActive="False" Width="20" Height="20" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid>
            <TextBlock Text="Python apps" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Content="Add Python app" Click="AddApp_Click" HorizontalAlignment="Right" Style="{StaticResource AccentButtonStyle}"/>
        </Grid>
        <Border BorderThickness="1" CornerRadius="8" Padding="4"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel>
                <TextBlock x:Name="EmptyApps" Text="No Python apps yet. Click “Add Python app”." Opacity="0.6" Padding="10" Visibility="Collapsed"/>
                <ListView x:Name="AppsList" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:PyAppRow">
                            <Grid Padding="8,6" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" Width="9" Height="9" Fill="{x:Bind DotBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{x:Bind Detail}" Opacity="0.7" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6">
                                    <Button Content="Open" Tag="{x:Bind Url}" Click="OpenApp_Click"/>
                                    <Button Content="Start" Tag="{x:Bind Name}" Click="StartApp_Click"/>
                                    <Button Content="Stop" Tag="{x:Bind Name}" Click="StopApp_Click"/>
                                    <Button ToolTipService.ToolTip="More">
                                        <FontIcon Glyph="&#xE712;" FontSize="14"/>
                                        <Button.Flyout>
                                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                <MenuFlyoutItem Text="Restart" Tag="{x:Bind Name}" Click="RestartApp_Click"/>
                                                <MenuFlyoutItem Text="pip install" Tag="{x:Bind Name}" Click="PipApp_Click"/>
                                                <MenuFlyoutSeparator/>
                                                <MenuFlyoutItem Text="Open folder" Tag="{x:Bind Name}" Click="FolderApp_Click"/>
                                                <MenuFlyoutItem Text="Open in code editor" Tag="{x:Bind Name}" Click="EditorApp_Click"/>
                                                <MenuFlyoutItem Text="Open terminal here" Tag="{x:Bind Name}" Click="TerminalApp_Click"/>
                                                <MenuFlyoutItem Text="View logs" Tag="{x:Bind Name}" Click="LogsApp_Click"/>
                                                <MenuFlyoutSeparator/>
                                                <MenuFlyoutItem Text="Remove" Tag="{x:Bind Name}" Click="RemoveApp_Click"/>
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>
    </StackPanel>
    </ScrollViewer>
</Page>
