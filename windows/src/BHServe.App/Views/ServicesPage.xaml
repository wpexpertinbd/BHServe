<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BHServe.App.Views.ServicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BHServe.App.Views">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="14">
            <Grid>
                <StackPanel Spacing="2">
                    <TextBlock Text="Services" FontSize="26" FontWeight="SemiBold"/>
                    <TextBlock Text="Install downloads portable builds on demand into BHServe's own bin folder."
                               Opacity="0.7"/>
                </StackPanel>
                <ProgressRing x:Name="Busy" IsActive="False" Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>

            <Border x:Name="OpBanner" Visibility="Collapsed" CornerRadius="8" Padding="12" BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                <StackPanel Spacing="6">
                    <Grid>
                        <TextBlock x:Name="OpName" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                            <TextBlock x:Name="OpPct" Opacity="0.7" VerticalAlignment="Center"/>
                            <Button x:Name="OpDismiss" Content="Dismiss" Click="OpDismiss_Click" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>
                    <ProgressBar x:Name="OpBar" Minimum="0" Maximum="100"/>
                    <TextBlock x:Name="OpMsg" Opacity="0.7" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <ItemsControl x:Name="Groups">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:SvcGroup">
                        <Border CornerRadius="8" Padding="10" Margin="0,0,0,8" BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" Opacity="0.8" Margin="4,2,0,6"/>
                                <ItemsControl ItemsSource="{x:Bind Rows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:SvcRow">
                                            <Grid Padding="6,5" ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="14"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="9" Height="9" Fill="{x:Bind DotBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{x:Bind Key}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{x:Bind StatusText}" Opacity="0.6" FontSize="12" VerticalAlignment="Center"/>
                                                <ToggleButton Grid.Column="3" Tag="{x:Bind Key}" IsChecked="{x:Bind AutoStart}" Click="AutoStar_Click"
                                                              ToolTipService.ToolTip="Start automatically" VerticalAlignment="Center" Padding="6"
                                                              Visibility="{x:Bind ManageVis}">
                                                    <FontIcon Glyph="&#xE734;" FontSize="13"/>
                                                </ToggleButton>
                                                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6">
                                                    <Button Content="Install" Tag="{x:Bind Key}" Click="Install_Click" IsEnabled="{x:Bind NotInstalled}"/>
                                                    <Button Content="Start"   Tag="{x:Bind Key}" Click="Start_Click"   IsEnabled="{x:Bind CanStart}" Visibility="{x:Bind ManageVis}"/>
                                                    <Button Content="Stop"    Tag="{x:Bind Key}" Click="Stop_Click"    IsEnabled="{x:Bind Running}" Visibility="{x:Bind ManageVis}"/>
                                                    <Button ToolTipService.ToolTip="More" IsEnabled="{x:Bind Installed}">
                                                        <FontIcon Glyph="&#xE712;" FontSize="14"/>
                                                        <Button.Flyout>
                                                            <MenuFlyout>
                                                                <MenuFlyoutItem Text="Edit php.ini" Tag="{x:Bind Key}" Click="EditIni_Click" Visibility="{x:Bind PhpVis}"/>
                                                                <MenuFlyoutItem Text="Reinstall (update)" Tag="{x:Bind Key}" Click="Update_Click"/>
                                                                <MenuFlyoutSeparator/>
                                                                <MenuFlyoutItem Text="Uninstall" Tag="{x:Bind Key}" Click="Uninstall_Click"/>
                                                            </MenuFlyout>
                                                        </Button.Flyout>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
