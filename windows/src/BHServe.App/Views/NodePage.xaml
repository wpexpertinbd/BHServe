<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BHServe.App.Views.NodePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BHServe.App.Views">

    <ScrollViewer>
    <StackPanel Padding="24" Spacing="16">
        <StackPanel Spacing="2">
            <TextBlock Text="Node.js" FontSize="26" FontWeight="SemiBold"/>
            <TextBlock Opacity="0.7" Text="Multiple Node versions via fnm + supervised Node-app sites"/>
        </StackPanel>

        <TextBlock Text="Versions" FontSize="16" FontWeight="SemiBold"/>
        <Border BorderThickness="1" CornerRadius="8" Padding="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBox x:Name="VerBox" PlaceholderText="version (e.g. 20, 22, lts)" Width="170"/>
                    <Button Content="Install" Click="Install_Click" Style="{StaticResource AccentButtonStyle}"/>
                    <ProgressRing x:Name="Busy" IsActive="False" Width="20" Height="20" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Quick install:" Opacity="0.7" VerticalAlignment="Center"/>
                    <Button Content="18"     Tag="18"     Click="Quick_Click"/>
                    <Button Content="20"     Tag="20"     Click="Quick_Click"/>
                    <Button Content="22"     Tag="22"     Click="Quick_Click"/>
                    <Button Content="24"     Tag="24"     Click="Quick_Click"/>
                    <Button Content="lts"    Tag="lts"    Click="Quick_Click"/>
                    <Button Content="latest" Tag="latest" Click="Quick_Click"/>
                </StackPanel>
                <TextBlock x:Name="EmptyVers" Text="No Node versions installed yet." Opacity="0.6" Visibility="Collapsed"/>
                <ItemsControl x:Name="VersList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:NodeVerRow">
                            <Grid Padding="4,5" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/><ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind Display}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" VerticalAlignment="Center" CornerRadius="4" Padding="7,2"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}" Visibility="{x:Bind DefaultVis}">
                                    <TextBlock Text="default" FontSize="11" Foreground="White"/>
                                </Border>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6">
                                    <Button Content="Use as default" Tag="{x:Bind Version}" Click="Use_Click" IsEnabled="{x:Bind NotDefault}"/>
                                    <Button Content="Uninstall" Tag="{x:Bind Version}" Click="UninstallVer_Click"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Grid>
            <TextBlock Text="Node apps" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Content="Add Node app" Click="AddApp_Click" HorizontalAlignment="Right" Style="{StaticResource AccentButtonStyle}"/>
        </Grid>
        <Border BorderThickness="1" CornerRadius="8" Padding="4"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <ListView x:Name="AppsList" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:NodeAppRow">
                        <Grid Padding="8,6" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="9" Height="9" Fill="{x:Bind DotBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{x:Bind Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{x:Bind Detail}" Opacity="0.7" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6">
                                <Button Content="Open" Tag="{x:Bind Url}" Click="OpenApp_Click"/>
                                <Button Content="Start" Tag="{x:Bind Name}" Click="StartApp_Click"/>
                                <Button Content="Stop" Tag="{x:Bind Name}" Click="StopApp_Click"/>
                                <Button ToolTipService.ToolTip="More">
                                    <FontIcon Glyph="&#xE712;" FontSize="14"/>
                                    <Button.Flyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="Restart" Tag="{x:Bind Name}" Click="RestartApp_Click"/>
                                            <MenuFlyoutItem Text="Open folder" Tag="{x:Bind Name}" Click="FolderApp_Click"/>
                                            <MenuFlyoutItem Text="View logs" Tag="{x:Bind Name}" Click="LogsApp_Click"/>
                                            <MenuFlyoutSeparator/>
                                            <MenuFlyoutItem Text="npm install (frontend)" Tag="{x:Bind Name}" Click="NpmFe_Click"/>
                                            <MenuFlyoutItem Text="npm install (backend)" Tag="{x:Bind Name}" Click="NpmBe_Click" Visibility="{x:Bind HasBackendVis}"/>
                                            <MenuFlyoutItem Text="Edit .env (frontend)" Tag="{x:Bind Name}" Click="EnvFe_Click"/>
                                            <MenuFlyoutItem Text="Edit .env (backend)" Tag="{x:Bind Name}" Click="EnvBe_Click" Visibility="{x:Bind HasBackendVis}"/>
                                            <MenuFlyoutItem Text="Edit config" Tag="{x:Bind Name}" Click="EditApp_Click"/>
                                            <MenuFlyoutSeparator/>
                                            <MenuFlyoutItem Text="Remove" Tag="{x:Bind Name}" Click="RemoveApp_Click"/>
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </StackPanel>
    </ScrollViewer>
</Page>
