<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BHServe.App.Views.SitesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BHServe.App.Views">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Sites" FontSize="26" FontWeight="SemiBold"/>

        <Border Grid.Row="1" BorderThickness="1" CornerRadius="8" Padding="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBox x:Name="NameBox" PlaceholderText="site name (e.g. myapp)" Width="180"/>
                <ComboBox x:Name="PhpBox" Width="100" SelectedIndex="0"/>
                <ComboBox x:Name="TypeBox" Width="150" SelectedIndex="0" SelectionChanged="Type_Changed">
                    <ComboBoxItem Content="WordPress"/>
                    <ComboBoxItem Content="PHP"/>
                    <ComboBoxItem Content="Others (static)"/>
                    <ComboBoxItem Content="Node app"/>
                </ComboBox>
                <ComboBox x:Name="ServerBox" Width="100" SelectedIndex="0">
                    <ComboBoxItem Content="nginx"/>
                    <ComboBoxItem Content="apache"/>
                </ComboBox>
                <Button x:Name="RootBtn" Click="PickRoot_Click" ToolTipService.ToolTip="Site root folder (optional — defaults to the Sites root)">
                    <FontIcon Glyph="&#xE8B7;" FontSize="14"/>
                </Button>
                <Button x:Name="AddBtn" Content="Add site" Click="Add_Click" Style="{StaticResource AccentButtonStyle}"/>
                <ProgressRing x:Name="Busy" IsActive="False" Width="20" Height="20"/>
            </StackPanel>
        </Border>

        <local:SiteListControl x:Name="SiteList" Grid.Row="2" VerticalAlignment="Top"/>
    </Grid>
</Page>
