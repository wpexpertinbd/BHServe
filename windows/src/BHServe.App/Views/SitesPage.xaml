<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BHServe.App.Views.SitesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BHServe.App.Views"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <TextBlock Text="Sites" FontSize="26" FontWeight="SemiBold"/>
            <TextBox x:Name="SearchBox" PlaceholderText="search…" Width="220" HorizontalAlignment="Right"
                     TextChanged="Search_Changed"/>
        </Grid>

        <Border Grid.Row="1" BorderThickness="1" CornerRadius="8" Padding="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBox x:Name="NameBox" PlaceholderText="site name (e.g. myapp)" Width="180"/>
                <ComboBox x:Name="PhpBox" Width="100" SelectedIndex="0"/>
                <ComboBox x:Name="TypeBox" Width="130" SelectedIndex="0">
                    <ComboBoxItem Content="others"/>
                    <ComboBoxItem Content="php"/>
                    <ComboBoxItem Content="wordpress"/>
                </ComboBox>
                <ComboBox x:Name="ServerBox" Width="100" SelectedIndex="0">
                    <ComboBoxItem Content="nginx"/>
                    <ComboBoxItem Content="apache"/>
                </ComboBox>
                <Button x:Name="AddBtn" Content="Add site" Click="Add_Click" Style="{StaticResource AccentButtonStyle}"/>
                <ProgressRing x:Name="Busy" IsActive="False" Width="20" Height="20"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" BorderThickness="1" CornerRadius="8" Padding="4"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <ListView x:Name="SitesList" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:SiteRow">
                        <Grid Padding="8,6" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="9" Height="9" Fill="{x:Bind DotBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{x:Bind Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <HyperlinkButton Grid.Column="2" Content="{x:Bind Url}" NavigateUri="{x:Bind Uri}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{x:Bind Php}" Opacity="0.7" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="2">
                                <Button Tag="{x:Bind Name}" Click="Open_Click"   ToolTipService.ToolTip="Open in browser"><FontIcon Glyph="&#xE774;" FontSize="14"/></Button>
                                <Button Tag="{x:Bind Name}" Click="Folder_Click" ToolTipService.ToolTip="Open folder"><FontIcon Glyph="&#xE8B7;" FontSize="14"/></Button>
                                <Button Tag="{x:Bind Name}" Click="Logs_Click"   ToolTipService.ToolTip="View error log"><FontIcon Glyph="&#xE9F9;" FontSize="14"/></Button>
                                <Button Tag="{x:Bind Name}" Click="Toggle_Click"  ToolTipService.ToolTip="Enable / disable"><FontIcon Glyph="&#xE7E8;" FontSize="14"/></Button>
                                <Button Tag="{x:Bind Name}" Click="Share_Click"  ToolTipService.ToolTip="Share publicly (Cloudflare)"><FontIcon Glyph="&#xE72D;" FontSize="14"/></Button>
                                <Button Tag="{x:Bind Domain}" Click="Secure_Click" IsEnabled="{x:Bind NotSecure}" ToolTipService.ToolTip="Enable HTTPS"><FontIcon Glyph="&#xE72E;" FontSize="14"/></Button>
                                <Button ToolTipService.ToolTip="More">
                                    <FontIcon Glyph="&#xE712;" FontSize="14"/>
                                    <Button.Flyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="Change PHP…" Tag="{x:Bind Name}" Click="ChangePhp_Click"/>
                                            <MenuFlyoutItem Text="Switch to nginx" Tag="{x:Bind Name}" Click="Nginx_Click"/>
                                            <MenuFlyoutItem Text="Switch to apache" Tag="{x:Bind Name}" Click="Apache_Click"/>
                                            <MenuFlyoutSeparator/>
                                            <MenuFlyoutItem Text="Delete" Tag="{x:Bind Name}" Click="Remove_Click"/>
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Page>
