<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BHServe.App.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BHServe.App.Views">

    <Page.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
        </Style>
    </Page.Resources>

    <ScrollViewer>
    <StackPanel Padding="24" Spacing="16">

        <!-- header + global actions -->
        <Grid>
            <StackPanel Spacing="2" VerticalAlignment="Center">
                <TextBlock Text="Dashboard" FontSize="26" FontWeight="SemiBold"/>
                <TextBlock x:Name="SubTitle" Opacity="0.7" Text="Local web stack"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="IonCubeBtn" Click="EnableIonCube_Click"
                        ToolTipService.ToolTip="Reload the ionCube Loader on all running PHP versions. Click this once after a reboot if a site shows &quot;the ionCube Loader needs to be installed&quot;.">
                    <StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xE83D;" FontSize="13"/><TextBlock Text="Enable ionCube"/></StackPanel>
                </Button>
                <Button x:Name="StartBtn" Click="StartAll_Click" Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xE768;" FontSize="13"/><TextBlock Text="Start all"/></StackPanel>
                </Button>
                <Button x:Name="StopBtn" Click="StopAll_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xE71A;" FontSize="13"/><TextBlock Text="Stop all"/></StackPanel>
                </Button>
                <Button x:Name="RestartBtn" Click="RestartAll_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xE72C;" FontSize="13"/><TextBlock Text="Restart"/></StackPanel>
                </Button>
                <ProgressRing x:Name="Busy" IsActive="False" Width="20" Height="20" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ionCube action result (hidden until the button / auto-run reports) -->
        <InfoBar x:Name="IonCubeResult" IsOpen="False" IsClosable="True"/>

        <!-- status cards: Web Server / PHP / Database / Cache -->
        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel Spacing="3">
                    <Grid>
                        <TextBlock Text="Web Server" Opacity="0.6" FontSize="12"/>
                        <Ellipse x:Name="WebDot" Width="9" Height="9" HorizontalAlignment="Right" Fill="Gray"/>
                    </Grid>
                    <TextBlock x:Name="WebVal" FontSize="18" FontWeight="SemiBold" Text="—"/>
                    <TextBlock x:Name="WebSub" Opacity="0.6" FontSize="12" Text=""/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel Spacing="3">
                    <Grid>
                        <TextBlock Text="PHP" Opacity="0.6" FontSize="12"/>
                        <Ellipse x:Name="PhpDot" Width="9" Height="9" HorizontalAlignment="Right" Fill="Gray"/>
                    </Grid>
                    <TextBlock x:Name="PhpVal" FontSize="18" FontWeight="SemiBold" Text="—" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="PhpSub" Opacity="0.6" FontSize="12" Text=""/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel Spacing="3">
                    <Grid>
                        <TextBlock Text="Database" Opacity="0.6" FontSize="12"/>
                        <Ellipse x:Name="DbDot" Width="9" Height="9" HorizontalAlignment="Right" Fill="Gray"/>
                    </Grid>
                    <TextBlock x:Name="DbVal" FontSize="18" FontWeight="SemiBold" Text="—"/>
                    <TextBlock x:Name="DbSub" Opacity="0.6" FontSize="12" Text=""/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource Card}">
                <StackPanel Spacing="3">
                    <Grid>
                        <TextBlock Text="Cache" Opacity="0.6" FontSize="12"/>
                        <Ellipse x:Name="CacheDot" Width="9" Height="9" HorizontalAlignment="Right" Fill="Gray"/>
                    </Grid>
                    <TextBlock x:Name="CacheVal" FontSize="18" FontWeight="SemiBold" Text="—"/>
                    <TextBlock x:Name="CacheSub" Opacity="0.6" FontSize="12" Text=""/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- metrics: CPU / Memory / Storage / Network -->
        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel Spacing="4"><TextBlock Text="CPU" Opacity="0.6" FontSize="12"/><TextBlock x:Name="CpuText" FontSize="20" FontWeight="SemiBold" Text="—"/>
                    <Viewbox Height="30" HorizontalAlignment="Stretch" Stretch="Fill">
                        <Canvas Width="200" Height="30"><Polyline x:Name="CpuSpark" Stroke="{ThemeResource AccentFillColorDefaultBrush}" StrokeThickness="1.5" StrokeLineJoin="Round"/></Canvas>
                    </Viewbox></StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel Spacing="4"><TextBlock Text="Memory" Opacity="0.6" FontSize="12"/><TextBlock x:Name="MemText" FontSize="20" FontWeight="SemiBold" Text="—"/><ProgressBar x:Name="MemBar" Minimum="0" Maximum="100"/></StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel Spacing="4"><TextBlock Text="Storage" Opacity="0.6" FontSize="12"/><TextBlock x:Name="DiskText" FontSize="20" FontWeight="SemiBold" Text="—"/><ProgressBar x:Name="DiskBar" Minimum="0" Maximum="100"/></StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource Card}">
                <StackPanel Spacing="4"><TextBlock Text="Network" Opacity="0.6" FontSize="12"/>
                    <TextBlock x:Name="NetDown" FontSize="14" FontWeight="SemiBold" Text="&#xE74B;  —"/>
                    <TextBlock x:Name="NetUp" FontSize="14" FontWeight="SemiBold" Text="&#xE74A;  —"/></StackPanel>
            </Border>
        </Grid>

        <!-- websites -->
        <Grid>
            <TextBlock x:Name="WebHeader" Text="Websites" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button x:Name="AddSiteBtn" Click="AddSite_Click" HorizontalAlignment="Right"
                    ToolTipService.ToolTip="Add a new site">
                <FontIcon Glyph="&#xE710;" FontSize="14"/>
            </Button>
        </Grid>
        <local:SiteListControl x:Name="SiteList"/>

        <!-- web tools -->
        <TextBlock Text="Web tools" FontSize="16" FontWeight="SemiBold"/>
        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel Spacing="8" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE968;" FontSize="16"/><TextBlock Text="phpMyAdmin" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="PmaStatus" Text="Off" Opacity="0.6" FontSize="12"/>
                    <Grid>
                        <ToggleSwitch x:Name="PmaToggle" OffContent="Off" OnContent="On" Toggled="Pma_Toggled"/>
                        <Button x:Name="PmaOpen" Content="Open" Click="PmaOpen_Click" HorizontalAlignment="Right" VerticalAlignment="Center" IsEnabled="False"/>
                    </Grid>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8A1;" FontSize="16"/><TextBlock Text="Adminer" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="AdmStatus" Text="Off" Opacity="0.6" FontSize="12"/>
                    <Grid>
                        <ToggleSwitch x:Name="AdmToggle" OffContent="Off" OnContent="On" Toggled="Adm_Toggled"/>
                        <Button x:Name="AdmOpen" Content="Open" Click="AdmOpen_Click" HorizontalAlignment="Right" VerticalAlignment="Center" IsEnabled="False"/>
                    </Grid>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE715;" FontSize="16"/><TextBlock Text="Mailpit" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="MailStatus" Text="Off" Opacity="0.6" FontSize="12"/>
                    <Grid>
                        <ToggleSwitch x:Name="MailToggle" OffContent="Off" OnContent="On" Toggled="Mail_Toggled"/>
                        <Button x:Name="MailOpen" Content="Open" Click="MailOpen_Click" HorizontalAlignment="Right" VerticalAlignment="Center" IsEnabled="False"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Expander Header="Activity log" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
            <ScrollViewer x:Name="LogScroll" Height="120">
                <TextBlock x:Name="LogBox" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Expander>
    </StackPanel>
    </ScrollViewer>
</Page>
