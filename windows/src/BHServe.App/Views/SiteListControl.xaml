<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="BHServe.App.Views.SiteListControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BHServe.App.Views">

    <!-- Grid (not StackPanel) so the list row is height-bounded when the control is given a
         bounded height (Sites page) — that lets the ListView's built-in ScrollViewer engage and
         virtualize. When the control is placed in an unbounded container (the Dashboard's outer
         ScrollViewer), the star row measures as content-size, so it still shows every row. -->
    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Show + search -->
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Show" Opacity="0.7" VerticalAlignment="Center"/>
                <ComboBox x:Name="ShowBox" Width="84" SelectionChanged="Show_Changed">
                    <ComboBoxItem Content="10"/>
                    <ComboBoxItem Content="15"/>
                    <ComboBoxItem Content="20"/>
                    <ComboBoxItem Content="50"/>
                    <ComboBoxItem Content="100"/>
                    <ComboBoxItem Content="All"/>
                </ComboBox>
                <ProgressRing x:Name="Busy" Width="18" Height="18" IsActive="False" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBox x:Name="SearchBox" PlaceholderText="search…" Width="220" HorizontalAlignment="Right" TextChanged="Search_Changed"/>
        </Grid>

        <!-- list -->
        <Border Grid.Row="1" BorderThickness="1" CornerRadius="8" Padding="4"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid>
                <TextBlock x:Name="Empty" Text="No sites yet." Opacity="0.6" Padding="10" Visibility="Collapsed"/>
                <ListView x:Name="List" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:SiteRow">
                            <Grid Padding="8,6" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" Width="9" Height="9" Fill="{x:Bind DotBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind Name}" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <HyperlinkButton Grid.Column="2" Content="{x:Bind Url}" NavigateUri="{x:Bind Uri}" VerticalAlignment="Center"/>
                                <Border Grid.Column="3" VerticalAlignment="Center" CornerRadius="4" Padding="7,2" Margin="0,0,6,0"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                    <TextBlock Text="{x:Bind Badge}" FontSize="11" Opacity="0.8"/>
                                </Border>
                                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="2">
                                    <Button Tag="{x:Bind Name}" Click="Open_Click"   ToolTipService.ToolTip="Open in browser"><FontIcon Glyph="&#xE774;" FontSize="14"/></Button>
                                    <Button Tag="{x:Bind Name}" Click="Folder_Click" ToolTipService.ToolTip="Open folder"><FontIcon Glyph="&#xE8B7;" FontSize="14"/></Button>
                                    <Button Tag="{x:Bind Name}" Click="Logs_Click"   ToolTipService.ToolTip="View error log"><FontIcon Glyph="&#xE9F9;" FontSize="14"/></Button>
                                    <Button Tag="{x:Bind Name}" Click="Toggle_Click" ToolTipService.ToolTip="Enable / disable"><FontIcon Glyph="&#xE7E8;" FontSize="14"/></Button>
                                    <Button Tag="{x:Bind Name}" Click="Share_Click"  ToolTipService.ToolTip="Share publicly (Cloudflare)"><FontIcon Glyph="&#xE72D;" FontSize="14"/></Button>
                                    <Button Tag="{x:Bind Domain}" Click="Secure_Click" IsEnabled="{x:Bind NotSecure}" ToolTipService.ToolTip="Enable HTTPS"><FontIcon Glyph="&#xE72E;" FontSize="14"/></Button>
                                    <Button ToolTipService.ToolTip="More">
                                        <FontIcon Glyph="&#xE712;" FontSize="14"/>
                                        <Button.Flyout>
                                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                <MenuFlyoutItem Text="Change PHP…" Tag="{x:Bind Name}" Click="ChangePhp_Click"/>
                                                <MenuFlyoutItem Text="Change root folder…" Tag="{x:Bind Name}" Click="ChangeRoot_Click"/>
                                                <MenuFlyoutItem Text="Switch to nginx" Tag="{x:Bind Name}" Click="Nginx_Click"/>
                                                <MenuFlyoutItem Text="Switch to apache" Tag="{x:Bind Name}" Click="Apache_Click"/>
                                                <MenuFlyoutSeparator/>
                                                <MenuFlyoutItem Text="Install SSL (HTTPS)" Tag="{x:Bind Domain}" Click="Secure_Click" IsEnabled="{x:Bind NotSecure}"/>
                                                <MenuFlyoutItem Text="Reinstall SSL (fresh certificate)" Tag="{x:Bind Domain}" Click="Resecure_Click" IsEnabled="{x:Bind Secure}"/>
                                                <MenuFlyoutItem Text="Remove SSL" Tag="{x:Bind Domain}" Click="Unsecure_Click" IsEnabled="{x:Bind Secure}"/>
                                                <MenuFlyoutSeparator/>
                                                <MenuFlyoutItem Text="Open in code editor" Tag="{x:Bind Name}" Click="CodeEditor_Click"/>
                                                <MenuFlyoutItem Text="Open terminal here" Tag="{x:Bind Name}" Click="Terminal_Click"/>
                                                <MenuFlyoutSeparator/>
                                                <MenuFlyoutItem Text="Delete" Tag="{x:Bind Name}" Click="Remove_Click"/>
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- pagination + jump -->
        <StackPanel x:Name="Pager" Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" Visibility="Collapsed">
            <Button x:Name="PrevBtn" Click="Prev_Click" ToolTipService.ToolTip="Previous"><FontIcon Glyph="&#xE76B;" FontSize="12"/></Button>
            <TextBlock x:Name="PageLabel" VerticalAlignment="Center" MinWidth="90" TextAlignment="Center"/>
            <Button x:Name="NextBtn" Click="Next_Click" ToolTipService.ToolTip="Next"><FontIcon Glyph="&#xE76C;" FontSize="12"/></Button>
            <TextBlock Text="Go to" VerticalAlignment="Center" Opacity="0.7" Margin="12,0,0,0"/>
            <NumberBox x:Name="JumpBox" Width="84" SpinButtonPlacementMode="Hidden" Minimum="1"/>
            <Button Content="Go" Click="Go_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
