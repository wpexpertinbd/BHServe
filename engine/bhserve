# ── Mailpit (mail catcher: SMTP :1025, web UI :8025) ─────────────────────────
cmd_mailpit(){ need_init; case "${1:-setup}" in setup) mailpit_setup ;; *) die "usage: bhserve mailpit setup" ;; esac; }
mailpit_setup(){
  svc_installed mailpit || die "mailpit not installed — bhserve install mailpit"
  brew services start mailpit >/dev/null 2>&1 || true
  enable_svc mailpit   # keep it in the auto-start set so Start All restarts it
  local tld; tld="$(jget tld test)"
  render_nginx_proxy_site mailpit "mailpit.$tld" 8025
  # route PHP mail() to Mailpit for every pool (sendmail_path picked up on regen)
  local k; for k in $(fpm_keys); do render_fpm_pool "$k" >/dev/null 2>&1 || true; done
  hdr "Mailpit ready"
  info "URL : http://mailpit.$tld   (SMTP 127.0.0.1:1025 · UI 127.0.0.1:8025)"
  info "PHP mail() now delivers to Mailpit (restart pools already done)"
  maybe_reload_nginx
}

# ── api (machine-readable JSON for the GUI) ──────────────────────────────────
json_esc(){ printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'; }

cmd_api() {
  need_init
  local cfg="$BH_HOME/config/bhserve.json"
  local brewlist; brewlist="$(brew services list 2>/dev/null || true)"
  local svcs="" first=1
  local IFS='|'
  while read -r key formula probe role; do
    [ -z "$key" ] && continue
    local installed=false running=false version=""
    if [ -x "$BREW_PREFIX/$probe" ]; then installed=true; version="$(probe_version "$BREW_PREFIX/$probe")"; fi
    case "$role" in
      web) [ "$key" = nginx ] && nginx_running && running=true ;;
      php) fpm_running "$key" && running=true ;;
      *)   printf '%s\n' "$brewlist" | awk -v f="$formula" '$1==f && $2=="started"{x=1} END{exit !x}' && running=true ;;
    esac
    local en=false; svc_enabled "$key" && en=true
    local row; row="$(printf '{"key":"%s","formula":"%s","role":"%s","installed":%s,"running":%s,"enabled":%s,"version":"%s"}' \
      "$key" "$formula" "$role" "$installed" "$running" "$en" "$(json_esc "$version")")"
    if [ "$first" = 1 ]; then svcs="$row"; first=0; else svcs="$svcs,$row"; fi
  done < <(services)

  local sites="" sfirst=1
  shopt -s nullglob
  for f in "$BH_HOME"/nginx/sites/*.conf "$BH_HOME"/nginx/sites/*.conf.disabled; do
    [ -e "$f" ] || continue
    local n dom php sec=false root enabled=true
    case "$f" in *.conf.disabled) enabled=false; n="$(basename "$f" .conf.disabled)";; *) n="$(basename "$f" .conf)";; esac
    dom="$(awk '/server_name/{print $2; exit}' "$f" | tr -d ';')"
    php="$(sed -n 's/.*php=\([^[:space:]]*\).*/\1/p' "$f" | head -1)"
    root="$(awk '/^[[:space:]]*root /{print $2; exit}' "$f" | tr -d ';')"
    grep -q "ssl_certificate " "$f" && sec=true
    local srv; srv="$(vhost_server "$f")"
    local row; row="$(printf '{"name":"%s","domain":"%s","php":"%s","root":"%s","secure":%s,"enabled":%s,"server":"%s"}' \
      "$n" "$dom" "$php" "$(json_esc "$root")" "$sec" "$enabled" "$srv")"
    if [ "$sfirst" = 1 ]; then sites="$row"; sfirst=0; else sites="$sites,$row"; fi
  done

  local helper=false; helper_installed && helper=true
  local brew=false; [ -n "$BREW" ] && brew=true
  printf '{"config":%s,"services":[%s],"sites":[%s],"helper":%s,"brew":%s}\n' "$(cat "$cfg")" "$svcs" "$sites" "$helper" "$brew"
}

# Install the core stack in one go (after Homebrew exists). Used by GUI onboarding.
cmd_bootstrap(){
  [ -n "$BREW" ] || die "Homebrew required first — install from https://brew.sh"
  cmd_init
  hdr "Installing core services"
  cmd_install nginx php@8.4 mariadb mkcert dnsmasq mailpit
  ok "core stack installed — add a site, then 'bhserve dns' + Start All"
}

# ── doctor / status ─────────────────────────────────────────────────────────
cmd_doctor() {
  hdr "BHServe doctor — environment"
  [ -n "$BREW" ] && ok "Homebrew: $(brew --version | head -1)  (prefix $BREW_PREFIX)" || no "Homebrew NOT found — install from https://brew.sh"
  if xcode-select -p >/dev/null 2>&1; then ok "Xcode CLT: $(xcode-select -p)"; else warn "Xcode/CLT not found (only needed to build the GUI app)"; fi
  [ -d "$BH_HOME" ] && ok "config root: $BH_HOME" || warn "not initialized — run: bhserve init"

  hdr "Engines (installed via Homebrew)"
  local IFS='|'
  while read -r key formula probe role; do
    [ -z "$key" ] && continue
    local bin="$BREW_PREFIX/$probe"
    if [ -x "$bin" ]; then
      ok "$(printf '%-14s' "$key") ${c_dim}$(probe_version "$bin")${c_reset}"
    else
      no "$(printf '%-14s' "$key") ${c_dim}not installed (bhserve install $key)${c_reset}"
    fi
  done < <(services)

  hdr "Ports & coexistence"
  for p in 80 443; do
    if lsof -nP -iTCP:"$p" -sTCP:LISTEN >/dev/null 2>&1; then warn "port $p is in use (likely ServBay/another server) — free it before BHServe binds it"; else ok "port $p is free"; fi
  done
  pgrep -lf -i servbay >/dev/null 2>&1 && warn "ServBay is running — stop it before starting BHServe web/DNS (you chose: own 80/443/.test)" || ok "ServBay not running"
  printf "\n${c_dim}Next: bhserve init · install <svc> · site add <name> · secure <name>.test · dns · start${c_reset}\n"
}

cmd_status() {
  hdr "BHServe status"
  if [ -f "$BH_HOME/config/bhserve.json" ]; then cat "$BH_HOME/config/bhserve.json"; else echo "  not initialized (run: bhserve init)"; return; fi
  hdr "Running"
  nginx_running && ok "nginx (pid $(cat "$BH_HOME/run/nginx.pid"))" || info "nginx stopped"
  for k in $(fpm_keys); do
    local pid; pid="$BH_HOME/run/php-$(php_label "$k").pid"
    if [ -f "$pid" ] && pid_alive "$(cat "$pid")"; then ok "php-fpm $k (pid $(cat "$pid"))"; else info "php-fpm $k stopped"; fi
  done
  site_list
}

usage(){ cat <<U
BHServe — usage:
  bhserve doctor                 check deps + ports + ServBay
  bhserve init                   create ~/.bhserve config root
  bhserve bootstrap              init + install the core stack (needs Homebrew)
  bhserve install <svc|all>      brew install a service
  bhserve update <svc|all>       brew upgrade a service
  bhserve uninstall <svc>        brew uninstall a service
  bhserve site add <name> [--php 8.4] [--root path] [--server nginx|apache]
  bhserve site list|rm <name>
  bhserve site php <name> <ver>  switch a site's PHP version
  bhserve db {list|create|drop|passwd} [name] [--engine mysql|pg] [--password PW]
  bhserve node {list|remote|install|use|uninstall} [version]   (multi-version via fnm)
  bhserve php {ioncube [version|all]|status}                   (ionCube loader + per-version config)
  bhserve site server <name> <nginx|apache>                   (switch a site's web server)
  bhserve pma install                                          (phpMyAdmin at phpmyadmin.test, 2GB uploads)
  bhserve adminer install                                      (Adminer at adminer.test)
  bhserve mailpit setup                                        (Mailpit catcher at mailpit.test; routes PHP mail())
  bhserve secure <domain>        trusted HTTPS via mkcert
  bhserve dns                    set up *.test (dnsmasq + resolver)
  bhserve config {show|set <key> <value>}   (http_port/https_port/tld/sites_root/default_php/default_web)
  bhserve logs [file.log|--list] [lines]
  bhserve start|stop|restart <svc|all>
  bhserve enable|disable <svc>                 (mark a service for auto-start)
  bhserve helper {install|uninstall|status}   (password-less nginx control)
  bhserve status
U
}

case "${1:-doctor}" in
  init)    cmd_init ;;
  doctor)  cmd_doctor ;;
  status)  cmd_status ;;
  api)     cmd_api ;;
  bootstrap) cmd_bootstrap ;;
  install) shift; cmd_install "$@" ;;
  update)  shift; cmd_update "$@" ;;
  uninstall) shift; cmd_uninstall "$@" ;;
  site)    shift; cmd_site "$@" ;;
  db)      shift; cmd_db "$@" ;;
  node)    shift; cmd_node "$@" ;;
  php)     shift; cmd_php "$@" ;;
  pma)     shift; cmd_pma "$@" ;;
  adminer) shift; cmd_adminer "$@" ;;
  mailpit) shift; cmd_mailpit "$@" ;;
  config)  shift; cmd_config "$@" ;;
  logs)    shift; cmd_logs "$@" ;;
  secure)  shift; cmd_secure "$@" ;;
  dns)     shift; cmd_dns "$@" ;;
  start)   shift; cmd_start "$@" ;;
  stop)    shift; cmd_stop "$@" ;;
  restart) shift; cmd_restart "$@" ;;
  reload)  need_init; nginx_reload ;;
  helper)  shift; cmd_helper "$@" ;;
  enable)  shift; cmd_enable "$@" ;;
  disable) shift; cmd_disable "$@" ;;
  help|-h|--help) usage ;;
  *) usage; exit 1 ;;
esac
