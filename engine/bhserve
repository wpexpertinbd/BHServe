#!/bin/bash
# BHServe — a free, self-controlled local dev environment for macOS (BiswasHost)
# Engine CLI. Manages PHP / Nginx / Apache / DBs / *.test / HTTPS over Homebrew.
set -euo pipefail

# When launched from a .app bundle (Finder), PATH is minimal and lacks Homebrew.
# Prepend the usual brew locations so `brew`, clients, etc. resolve either way.
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/local/sbin:$PATH"

BH_HOME="${BHSERVE_HOME:-$HOME/.bhserve}"
BREW="$(command -v brew || true)"
BREW_PREFIX="$([ -n "$BREW" ] && brew --prefix || echo /opt/homebrew)"
TLD="test"
USER_NAME="$(id -un)"
GROUP_NAME="$(id -gn)"

c_reset=$'\033[0m'; c_g=$'\033[32m'; c_r=$'\033[31m'; c_y=$'\033[33m'; c_dim=$'\033[2m'; c_b=$'\033[1m'
ok(){ printf "  ${c_g}✓${c_reset} %s\n" "$*"; }
no(){ printf "  ${c_r}✗${c_reset} %s\n" "$*"; }
warn(){ printf "  ${c_y}!${c_reset} %s\n" "$*"; }
hdr(){ printf "\n${c_b}%s${c_reset}\n" "$*"; }
die(){ no "$*"; exit 1; }
info(){ printf "  ${c_dim}%s${c_reset}\n" "$*"; }

# Service registry:  key | brew formula | version-probe binary (relative to brew prefix) | role
services() {
  cat <<EOF
php|php|bin/php|php
php@8.6|shivammathur/php/php@8.6|opt/php@8.6/bin/php|php
php@8.5|php@8.5|opt/php@8.5/bin/php|php
php@8.4|php@8.4|opt/php@8.4/bin/php|php
php@8.3|php@8.3|opt/php@8.3/bin/php|php
php@8.2|php@8.2|opt/php@8.2/bin/php|php
php@8.1|php@8.1|opt/php@8.1/bin/php|php
nginx|nginx|bin/nginx|web
httpd|httpd|bin/httpd|web
mariadb|mariadb|opt/mariadb/bin/mariadb|db
mysql|mysql|opt/mysql/bin/mysql|db
postgresql@17|postgresql@17|opt/postgresql@17/bin/postgres|db
redis|redis|bin/redis-server|cache
memcached|memcached|bin/memcached|cache
dnsmasq|dnsmasq|sbin/dnsmasq|dns
mkcert|mkcert|bin/mkcert|tls
mailpit|mailpit|bin/mailpit|mail
fnm|fnm|bin/fnm|node
EOF
}

# ── helpers ───────────────────────────────────────────────────────────────
svc_formula(){ services | awk -F'|' -v k="$1" '$1==k{print $2}'; }
svc_probe(){   services | awk -F'|' -v k="$1" '$1==k{print $3}'; }
svc_role(){    services | awk -F'|' -v k="$1" '$1==k{print $4}'; }
svc_exists(){  services | awk -F'|' -v k="$1" '$1==k{f=1} END{exit !f}'; }
svc_installed(){ local p; p="$(svc_probe "$1")"; [ -n "$p" ] && [ -x "$BREW_PREFIX/$p" ]; }

# ── auto-start set ("default" services) ──────────────────────────────────────
# Which services 'start all' brings up. Stored one key per line; when the file is
# absent, a sensible default set applies (nginx + default PHP + MariaDB).
ENABLED_FILE(){ echo "$BH_HOME/config/enabled"; }
svc_default_enabled(){
  case "$1" in
    nginx|mariadb) return 0 ;;
    php@*|php) [ "$1" = "$(php_key default)" ] && return 0 || return 1 ;;
    *) return 1 ;;
  esac
}
svc_enabled(){
  local f; f="$(ENABLED_FILE)"
  if [ -f "$f" ]; then grep -qxF "$1" "$f"; else svc_default_enabled "$1"; fi
}
materialize_enabled(){
  local f; f="$(ENABLED_FILE)"; [ -f "$f" ] && return 0
  local IFS='|' key _a _b _c; : > "$f"
  while read -r key _a _b _c; do [ -n "$key" ] && svc_default_enabled "$key" && echo "$key" >> "$f"; done < <(services)
  return 0
}
enable_svc(){ materialize_enabled; local f; f="$(ENABLED_FILE)"; grep -qxF "$1" "$f" || echo "$1" >> "$f"; }
disable_svc(){ materialize_enabled; local f; f="$(ENABLED_FILE)"; grep -vxF "$1" "$f" > "$f.tmp" 2>/dev/null && mv "$f.tmp" "$f" || true; }

cmd_enable(){ need_init; [ $# -ge 1 ] || die "usage: bhserve enable <svc>"; svc_exists "$1" || die "unknown service: $1"; enable_svc "$1"; ok "$1 will auto-start"; }
cmd_disable(){ need_init; [ $# -ge 1 ] || die "usage: bhserve disable <svc>"; disable_svc "$1"; ok "$1 won't auto-start"; }

# Version probe — robust under `set -e`/pipefail. nginx/httpd reject --version
# and print to stderr, so fall back to -v; never propagate a non-zero exit.
probe_version(){
  local bin="$1" out=""
  out="$("$bin" --version 2>&1 | head -1)" || true
  case "$out" in *"invalid option"*|*"unknown option"*|"") out="$("$bin" -v 2>&1 | head -1)" || true ;; esac
  printf '%s' "$out" | tr -d '\n' | cut -c1-46
}

# Normalize a --php value ("8.4", "php@8.4", "default", "") to a registry key.
php_key(){
  local v="${1:-}"
  case "$v" in
    ""|default) v="$(jget default_php 8.4)" ;;
  esac
  case "$v" in
    php) echo php ;;
    php@*) echo "$v" ;;
    *) echo "php@$v" ;;
  esac
}

# php-fpm binary for a php registry key.
php_fpm_bin(){
  local key="$1"
  if [ "$key" = "php" ]; then echo "$BREW_PREFIX/sbin/php-fpm"
  else echo "$BREW_PREFIX/opt/$key/sbin/php-fpm"; fi
}

# Sanitized socket label for a php key:  php@8.4 -> 8.4 ; php -> default
php_label(){ local k="$1"; [ "$k" = "php" ] && echo default || echo "${k#php@}"; }
php_sock(){ echo "$BH_HOME/run/php-$(php_label "$1").sock"; }

# Tiny JSON getter (string/number values) from bhserve.json, with fallback.
jget(){
  local key="$1" fb="${2:-}" cfg="$BH_HOME/config/bhserve.json" v
  [ -f "$cfg" ] || { echo "$fb"; return; }
  v="$(sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\"\{0,1\}\([^\",}]*\)\"\{0,1\}.*/\1/p" "$cfg" | head -1)"
  [ -n "$v" ] && echo "$v" || echo "$fb"
}

need_init(){ [ -d "$BH_HOME/config" ] || die "not initialized — run: bhserve init"; }

# Does a pid exist? Uses ps (ownership-independent) so a non-root caller can
# still see the root-owned nginx master (kill -0 would EPERM-fail there).
pid_alive(){ local p="${1:-}"; [ -n "$p" ] && ps -p "$p" >/dev/null 2>&1; }

# ── init ────────────────────────────────────────────────────────────────────
cmd_init() {
  hdr "Initializing BHServe at $BH_HOME"
  for d in config nginx/sites apache/sites php logs run sites certs tmp; do mkdir -p "$BH_HOME/$d"; done
  for d in client_body proxy fastcgi uwsgi scgi; do mkdir -p "$BH_HOME/tmp/$d"; done
  local cfg="$BH_HOME/config/bhserve.json"
  if [ ! -f "$cfg" ]; then
    cat > "$cfg" <<JSON
{
  "tld": "test",
  "http_port": 80,
  "https_port": 443,
  "default_php": "8.4",
  "default_web": "nginx",
  "brew_prefix": "$BREW_PREFIX",
  "sites_root": "$HOME/Sites",
  "autostart": false
}
JSON
    ok "wrote default config: $cfg"
  else
    ok "config already exists: $cfg"
  fi
  render_nginx_main
  ok "directories ready under $BH_HOME"
}

# ── install (brew wrapper) ───────────────────────────────────────────────────
cmd_install() {
  need_init
  [ $# -ge 1 ] || die "usage: bhserve install <svc|all>  (e.g. nginx, httpd, dnsmasq, mkcert, redis, postgresql@17, mailpit, node)"
  [ -n "$BREW" ] || die "Homebrew not found — install from https://brew.sh"
  local targets=()
  if [ "$1" = "all" ]; then
    while IFS='|' read -r key _ _ _; do [ -n "$key" ] && targets+=("$key"); done < <(services)
  else
    targets=("$@")
  fi
  for key in "${targets[@]}"; do
    svc_exists "$key" || { warn "unknown service: $key (skipped)"; continue; }
    if svc_installed "$key"; then ok "$key already installed"; continue; fi
    local formula; formula="$(svc_formula "$key")"
    hdr "Installing $key  (brew install $formula)"
    brew install "$formula" && ok "$key installed" || no "brew install $formula failed"
  done
}

# Stop a service (any role) before uninstall/reconfig.
svc_stop_any(){
  case "$(svc_role "$1")" in
    php) fpm_stop "$1" >/dev/null 2>&1 || true ;;
    web) [ "$1" = nginx ] && nginx_stop >/dev/null 2>&1; [ "$1" = httpd ] && apache_stop >/dev/null 2>&1 || true ;;
    db|cache|mail) brew_svc stop "$1" >/dev/null 2>&1 || true ;;
  esac
}

cmd_update() {
  need_init; [ $# -ge 1 ] || die "usage: bhserve update <svc|all>"
  [ -n "$BREW" ] || die "Homebrew not found"
  if [ "$1" = all ]; then hdr "Updating Homebrew + all formulae"; brew update >/dev/null 2>&1 || true; brew upgrade && ok "all up to date" || warn "upgrade had issues"; return; fi
  brew update >/dev/null 2>&1 || true
  for key in "$@"; do
    svc_exists "$key" || { warn "unknown service: $key"; continue; }
    svc_installed "$key" || { warn "$key not installed"; continue; }
    local f; f="$(svc_formula "$key")"
    hdr "Updating $key  (brew upgrade $f)"
    brew upgrade "$f" 2>&1 | tail -2 || true
    ok "$key at $(probe_version "$BREW_PREFIX/$(svc_probe "$key")")"
  done
}

cmd_uninstall() {
  need_init; [ $# -ge 1 ] || die "usage: bhserve uninstall <svc>"
  [ -n "$BREW" ] || die "Homebrew not found"
  for key in "$@"; do
    svc_exists "$key" || { warn "unknown service: $key"; continue; }
    svc_installed "$key" || { warn "$key not installed"; continue; }
    local f; f="$(svc_formula "$key")"
    hdr "Uninstalling $key  (brew uninstall $f)"
    svc_stop_any "$key"
    brew uninstall "$f" && ok "$key uninstalled" || no "uninstall failed (a dependency may need it)"
  done
}

# ── nginx config generation ──────────────────────────────────────────────────
render_nginx_main() {
  local conf="$BH_HOME/nginx/nginx.conf"
  cat > "$conf" <<NGINX
# Generated by BHServe — do not edit by hand (regenerated on init / site changes).
# Master runs as root (to bind :80/:443); workers drop to the invoking user so
# they can read the user-owned PHP-FPM sockets and mkcert keys (else 502 / TLS fail).
user $USER_NAME $GROUP_NAME;
worker_processes auto;
worker_rlimit_nofile 65535;
error_log $BH_HOME/logs/nginx-error.log;
pid $BH_HOME/run/nginx.pid;
events {
    worker_connections 4096;
    multi_accept on;
}
http {
    include $BREW_PREFIX/etc/nginx/mime.types;
    default_type application/octet-stream;
    access_log $BH_HOME/logs/nginx-access.log;
    client_body_temp_path $BH_HOME/tmp/client_body;
    proxy_temp_path       $BH_HOME/tmp/proxy;
    fastcgi_temp_path     $BH_HOME/tmp/fastcgi;
    uwsgi_temp_path       $BH_HOME/tmp/uwsgi;
    scgi_temp_path        $BH_HOME/tmp/scgi;

    # performance
    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;
    keepalive_timeout 65;
    reset_timedout_connection on;
    types_hash_max_size 4096;
    server_names_hash_bucket_size 128;
    server_tokens off;
    client_max_body_size 2048m;
    client_body_buffer_size 256k;
    client_header_buffer_size 4k;
    large_client_header_buffers 4 16k;

    # fastcgi tuning (big apps + slow imports)
    fastcgi_buffers 16 16k;
    fastcgi_buffer_size 32k;
    fastcgi_busy_buffers_size 64k;
    fastcgi_read_timeout 600;
    fastcgi_connect_timeout 60;

    # static-file fd cache
    open_file_cache max=10000 inactive=30s;
    open_file_cache_valid 60s;
    open_file_cache_min_uses 2;
    open_file_cache_errors on;

    # gzip
    gzip on;
    gzip_comp_level 5;
    gzip_min_length 256;
    gzip_proxied any;
    gzip_vary on;
    gzip_types text/plain text/css text/xml text/javascript application/json
               application/javascript application/xml application/xml+rss
               application/rss+xml image/svg+xml application/wasm font/ttf font/otf;

    # Catch-all default so an unknown host doesn't leak the first site.
    server {
        listen ${1:-80} default_server;
        server_name _;
        return 444;
    }

    include $BH_HOME/nginx/sites/*.conf;
}
NGINX
  ok "nginx main config: $conf"
}

APACHE_PORT=8080

# Render a site. server=nginx → nginx serves PHP directly (fast, no .htaccess).
# server=apache → nginx fronts (TLS/80/443) and proxies the host to Apache on
# :8080, which serves with AllowOverride All so .htaccess works natively.
render_site_vhost() {
  local name="$1" domain="$2" root="$3" phpkey="$4" server="${5:-nginx}"
  if [ "$server" = apache ]; then
    render_apache_vhost "$name" "$domain" "$root" "$phpkey"
    render_nginx_proxy_vhost "$name" "$domain" "$root" "$phpkey"
  else
    render_nginx_php_vhost "$name" "$domain" "$root" "$phpkey"
  fi
}

# common: emit the nginx listen/ssl lines for a domain
nginx_listen_block() {
  local domain="$1" http https cert key
  http="$(jget http_port 80)"; https="$(jget https_port 443)"
  cert="$BH_HOME/certs/$domain.pem"; key="$BH_HOME/certs/$domain-key.pem"
  printf '    listen %s;\n' "$http"
  if [ -f "$cert" ] && [ -f "$key" ]; then
    printf '    listen %s ssl;\n    ssl_certificate %s;\n    ssl_certificate_key %s;\n' "$https" "$cert" "$key"
  else
    printf '    # HTTPS not provisioned — run: bhserve secure %s\n' "$domain"
  fi
}

render_nginx_php_vhost() {
  local name="$1" domain="$2" root="$3" phpkey="$4" sock conf
  sock="$(php_sock "$phpkey")"; conf="$BH_HOME/nginx/sites/$name.conf"
  cat > "$conf" <<NGINX
# BHServe site: $name  ($domain)  php=$phpkey server=nginx
server {
$(nginx_listen_block "$domain")
    server_name $domain;
    root $root;
    index index.php index.html index.htm;

    access_log $BH_HOME/logs/$name-access.log;
    error_log  $BH_HOME/logs/$name-error.log;

    location / { try_files \$uri \$uri/ /index.php?\$query_string; }

    location ~ \.php\$ {
        try_files \$uri =404;
        include $BREW_PREFIX/etc/nginx/fastcgi_params;
        fastcgi_pass unix:$sock;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME \$document_root\$fastcgi_script_name;
        fastcgi_param PATH_INFO \$fastcgi_path_info;
    }

    location ~ /\.(?!well-known).* { deny all; }
}
NGINX
  ok "site vhost (nginx): $conf"
}

# nginx front that proxies the whole host to Apache (which serves + .htaccess)
render_nginx_proxy_vhost() {
  local name="$1" domain="$2" root="$3" phpkey="$4" conf="$BH_HOME/nginx/sites/$1.conf"
  cat > "$conf" <<NGINX
# BHServe site: $name  ($domain)  php=$phpkey server=apache
server {
$(nginx_listen_block "$domain")
    server_name $domain;
    root $root;   # served by Apache (:$APACHE_PORT); kept for tooling/metadata

    access_log $BH_HOME/logs/$name-access.log;
    error_log  $BH_HOME/logs/$name-error.log;

    location / {
        proxy_pass http://127.0.0.1:$APACHE_PORT;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_read_timeout 600;
    }
}
NGINX
  ok "site vhost (nginx→apache): $conf"
}

# Generic nginx vhost proxying a host to a local HTTP port (e.g. Mailpit :8025).
render_nginx_proxy_site() {
  local name="$1" domain="$2" port="$3" conf="$BH_HOME/nginx/sites/$1.conf"
  cat > "$conf" <<NGINX
# BHServe site: $name  ($domain)  php=- server=proxy
server {
$(nginx_listen_block "$domain")
    server_name $domain;
    location / {
        proxy_pass http://127.0.0.1:$port;
        proxy_set_header Host \$host;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 600;
    }
}
NGINX
  ok "site vhost (proxy → :$port): $conf"
}

render_apache_vhost() {
  local name="$1" domain="$2" root="$3" phpkey="$4" sock conf
  sock="$(php_sock "$phpkey")"; conf="$BH_HOME/apache/sites/$name.conf"
  mkdir -p "$BH_HOME/apache/sites"
  cat > "$conf" <<APACHE
# BHServe Apache backend: $name ($domain) php=$phpkey
<VirtualHost 127.0.0.1:$APACHE_PORT>
    ServerName $domain
    DocumentRoot "$root"
    <Directory "$root">
        Options Indexes FollowSymLinks
        AllowOverride All
        Require all granted
    </Directory>
    <FilesMatch \.php\$>
        SetHandler "proxy:unix:$sock|fcgi://localhost/"
    </FilesMatch>
    ErrorLog "$BH_HOME/logs/$name-apache-error.log"
</VirtualHost>
APACHE
  ok "site vhost (apache): $conf"
}

render_apache_main() {
  local conf="$BH_HOME/apache/httpd.conf" moddir="$BREW_PREFIX/opt/httpd/lib/httpd/modules"
  mkdir -p "$BH_HOME/apache/sites"
  cat > "$conf" <<APACHE
# Generated by BHServe — Apache backend behind nginx. Do not edit by hand.
ServerRoot "$BREW_PREFIX/opt/httpd"
Listen 127.0.0.1:$APACHE_PORT
LoadModule mpm_event_module $moddir/mod_mpm_event.so
LoadModule authz_core_module $moddir/mod_authz_core.so
LoadModule unixd_module $moddir/mod_unixd.so
LoadModule dir_module $moddir/mod_dir.so
LoadModule mime_module $moddir/mod_mime.so
LoadModule rewrite_module $moddir/mod_rewrite.so
LoadModule headers_module $moddir/mod_headers.so
LoadModule setenvif_module $moddir/mod_setenvif.so
LoadModule log_config_module $moddir/mod_log_config.so
LoadModule env_module $moddir/mod_env.so
LoadModule alias_module $moddir/mod_alias.so
LoadModule proxy_module $moddir/mod_proxy.so
LoadModule proxy_fcgi_module $moddir/mod_proxy_fcgi.so
ServerName localhost
User $USER_NAME
Group $GROUP_NAME
PidFile "$BH_HOME/run/httpd.pid"
DefaultRuntimeDir "$BH_HOME/run"
TypesConfig "$BREW_PREFIX/etc/httpd/mime.types"
DirectoryIndex index.php index.html index.htm
ErrorLog "$BH_HOME/logs/apache-error.log"
LogLevel warn
LimitRequestBody 0
<Directory />
    AllowOverride none
    Require all denied
</Directory>
IncludeOptional $BH_HOME/apache/sites/*.conf
APACHE
  ok "apache main config: $conf"
}

# ── apache process (internal :8080, no sudo) ─────────────────────────────────
APACHE_BIN(){ echo "$BREW_PREFIX/opt/httpd/bin/httpd"; }
apache_running(){ local p="$BH_HOME/run/httpd.pid"; [ -f "$p" ] && pid_alive "$(cat "$p")"; }
have_apache_sites(){ grep -lq "server=apache" "$BH_HOME"/nginx/sites/*.conf 2>/dev/null; }

apache_start(){
  local bin; bin="$(APACHE_BIN)"; [ -x "$bin" ] || { warn "httpd not installed — bhserve install httpd"; return 1; }
  render_apache_main
  if apache_running; then ok "apache already running (:$APACHE_PORT)"; return 0; fi
  "$bin" -f "$BH_HOME/apache/httpd.conf" -k start && ok "apache started (:$APACHE_PORT)" || no "apache failed to start"
}
apache_stop(){
  local bin; bin="$(APACHE_BIN)"
  if apache_running; then "$bin" -f "$BH_HOME/apache/httpd.conf" -k stop && ok "apache stopped" || no "apache stop failed"
  else info "apache not running"; fi
}
apache_reload(){ apache_running || return 0; "$(APACHE_BIN)" -f "$BH_HOME/apache/httpd.conf" -k graceful 2>/dev/null && ok "apache reloaded" || true; }

# ── PHP-FPM pools ─────────────────────────────────────────────────────────────
render_fpm_pool() {
  local key="$1" label sock conf binp
  label="$(php_label "$key")"
  sock="$(php_sock "$key")"
  conf="$BH_HOME/php/php-$label.conf"
  binp="$(php_fpm_bin "$key")"
  [ -x "$binp" ] || { warn "$key not installed; skipping pool (brew install $(svc_formula "$key"))"; return 1; }
  cat > "$conf" <<FPM
; BHServe PHP-FPM pool — $key
[global]
pid = $BH_HOME/run/php-$label.pid
error_log = $BH_HOME/logs/php-$label.log
daemonize = yes

[www]
; Set so php-fpm works whether started as the user (directive ignored) or as root
; via an elevated 'start all' (workers then drop to the user, not root → sockets stay
; user-owned so nginx workers can read them).
user = $USER_NAME
group = $GROUP_NAME
listen = $sock
listen.owner = $USER_NAME
listen.group = $GROUP_NAME
listen.mode = 0660
pm = dynamic
pm.max_children = 12
pm.start_servers = 2
pm.min_spare_servers = 1
pm.max_spare_servers = 4
pm.max_requests = 500
php_admin_value[error_log] = $BH_HOME/logs/php-$label.error.log
php_admin_flag[log_errors] = on
; ── BHServe defaults: big uploads (phpMyAdmin 2GB) + app-friendly limits ──
php_admin_value[upload_max_filesize] = 2048M
php_admin_value[post_max_size] = 2048M
php_admin_value[memory_limit] = 512M
php_admin_value[max_execution_time] = 600
php_admin_value[max_input_time] = 600
php_admin_value[max_input_vars] = 10000
php_admin_value[date.timezone] = UTC
php_admin_value[opcache.enable] = 1
php_admin_value[opcache.memory_consumption] = 192
php_admin_value[opcache.max_accelerated_files] = 20000
php_admin_value[realpath_cache_size] = 4096k
FPM
  # route mail() to Mailpit when it's installed (sendmail-compatible shim)
  if svc_installed mailpit; then
    printf 'php_admin_value[sendmail_path] = %s/bin/mailpit sendmail -t --smtp-addr 127.0.0.1:1025\n' "$BREW_PREFIX" >> "$conf"
  fi
  ok "php-fpm pool: $conf  (socket $sock)"
  # auto-apply: if this pool is already running, restart it so new settings take
  # effect immediately (sudo-free — FPM runs as the user). Fixes "changed config
  # but the live pool still has the old values".
  if fpm_running "$key"; then
    fpm_stop "$key" >/dev/null 2>&1 || true
    fpm_start "$key" >/dev/null 2>&1 && ok "php-fpm $key reloaded (new settings)" || true
  fi
}

fpm_start(){
  local key="$1" label conf binp pid
  label="$(php_label "$key")"; conf="$BH_HOME/php/php-$label.conf"; binp="$(php_fpm_bin "$key")"
  [ -f "$conf" ] || render_fpm_pool "$key" || return 1
  [ -x "$binp" ] || { warn "$key php-fpm missing"; return 1; }
  pid="$BH_HOME/run/php-$label.pid"
  if [ -f "$pid" ] && pid_alive "$(cat "$pid")"; then ok "php-fpm $key already running (pid $(cat "$pid"))"; return 0; fi
  # Load BHServe's per-version conf.d (ionCube etc.) in addition to brew defaults
  # (leading ':' keeps the compiled-in scan dir). Created empty if unused.
  local cd_dir="$BH_HOME/php/conf.d/$label"; mkdir -p "$cd_dir"
  PHP_INI_SCAN_DIR=":$cd_dir" "$binp" -y "$conf" -p "$BH_HOME" && ok "php-fpm $key started" || no "php-fpm $key failed to start"
}
fpm_stop(){
  local key="$1" label pid
  label="$(php_label "$key")"; pid="$BH_HOME/run/php-$label.pid"
  if [ -f "$pid" ] && pid_alive "$(cat "$pid")"; then kill "$(cat "$pid")" && ok "php-fpm $key stopped"; else info "php-fpm $key not running"; fi
}

# Which php keys have a generated pool conf?
fpm_keys(){ ls "$BH_HOME"/php/php-*.conf 2>/dev/null | sed -E 's#.*/php-(.*)\.conf#\1#' | while read -r l; do [ "$l" = default ] && echo php || echo "php@$l"; done; }

# ── sites ─────────────────────────────────────────────────────────────────────
cmd_site() {
  need_init
  local sub="${1:-list}"; shift || true
  case "$sub" in
    add) site_add "$@" ;;
    rm|remove) site_rm "$@" ;;
    list|ls) site_list ;;
    php) site_set_php "$@" ;;
    server) site_set_server "$@" ;;
    enable)  site_toggle "${1:-}" on ;;
    disable) site_toggle "${1:-}" off ;;
    *) die "usage: bhserve site {add|rm|list|php|server|enable|disable}" ;;
  esac
}

# Switch a site between nginx (direct) and apache (proxy + .htaccess).
site_set_server() {
  [ $# -ge 2 ] || die "usage: bhserve site server <name> <nginx|apache>"
  local name="$1" newsrv="$2" conf="$BH_HOME/nginx/sites/$1.conf"
  [ -f "$conf" ] || die "no site '$name'"
  case "$newsrv" in nginx|apache) ;; *) die "server must be nginx or apache" ;; esac
  [ "$newsrv" != apache ] || svc_installed httpd || die "apache needs httpd — bhserve install httpd"
  local domain root php
  domain="$(awk '/server_name/{print $2; exit}' "$conf" | tr -d ';')"
  root="$(awk '/^[[:space:]]*root /{print $2; exit}' "$conf" | tr -d ';')"
  php="$(sed -n 's/.*php=\([^[:space:]]*\).*/\1/p' "$conf" | head -1)"
  [ "$newsrv" = nginx ] && rm -f "$BH_HOME/apache/sites/$name.conf"
  render_site_vhost "$name" "$domain" "$root" "$php" "$newsrv"
  [ "$newsrv" = apache ] && apache_start >/dev/null 2>&1 || true
  ok "$name now served by $newsrv"
  apache_reload; maybe_reload_nginx
}

# Enable/disable serving a site by toggling its vhost file extension
# (nginx only includes *.conf). Caller reloads nginx to apply.
site_toggle(){
  local name="$1" mode="$2"
  [ -n "$name" ] || die "usage: bhserve site {enable|disable} <name>"
  local on="$BH_HOME/nginx/sites/$name.conf" off="$BH_HOME/nginx/sites/$name.conf.disabled"
  if [ "$mode" = off ]; then
    [ -f "$on" ] && mv "$on" "$off" && ok "disabled $name" || warn "$name already disabled / missing"
  else
    [ -f "$off" ] && mv "$off" "$on" && ok "enabled $name" || warn "$name already enabled / missing"
  fi
  maybe_reload_nginx
}

# Switch a site's PHP version: re-render its vhost against the new pool socket,
# ensure that pool exists + is running, then reload nginx (caller/GUI does that).
site_set_php() {
  [ $# -ge 2 ] || die "usage: bhserve site php <name> <8.4|php@8.4>"
  local name="$1" newphp="$2" conf="$BH_HOME/nginx/sites/$1.conf"
  [ -f "$conf" ] || die "no site '$name'"
  local domain root phpkey server
  domain="$(awk '/server_name/{print $2; exit}' "$conf" | tr -d ';')"
  root="$(awk '/^[[:space:]]*root /{print $2; exit}' "$conf" | tr -d ';')"
  server="$(vhost_server "$conf")"
  phpkey="$(php_key "$newphp")"
  svc_installed "$phpkey" || die "$phpkey not installed (bhserve install $phpkey)"
  render_fpm_pool "$phpkey" || true
  fpm_start "$phpkey" >/dev/null 2>&1 || true
  render_site_vhost "$name" "$domain" "$root" "$phpkey" "$server"
  ok "$name now uses $phpkey"
  [ "$server" = apache ] && apache_reload || true
  maybe_reload_nginx
}

# server type recorded in the vhost comment (default nginx for older vhosts)
vhost_server(){ local s; s="$(sed -n 's/.*server=\([^ ]*\).*/\1/p' "$1" | head -1)"; echo "${s:-nginx}"; }

site_add() {
  local name="" root="" phpv="" server=""
  [ $# -ge 1 ] || die "usage: bhserve site add <name> [--php 8.4] [--root path] [--server nginx|apache]"
  name="$1"; shift
  while [ $# -gt 0 ]; do case "$1" in
    --php) phpv="$2"; shift 2;;
    --root) root="$2"; shift 2;;
    --server) server="$2"; shift 2;;
    *) die "unknown flag: $1";;
  esac; done
  local tld; tld="$(jget tld test)"
  local domain="$name.$tld"
  [ -n "$root" ] || root="$(jget sites_root "$HOME/Sites")/$name"
  [ -n "$server" ] || server="$(jget default_web nginx)"
  local phpkey; phpkey="$(php_key "$phpv")"

  mkdir -p "$root"
  [ -f "$root/index.php" ] || cat > "$root/index.php" <<PHP
<?php // BHServe placeholder for $domain
echo "<h1>$domain</h1><p>BHServe is serving this site on PHP " . PHP_VERSION . ".</p>";
phpinfo(INFO_GENERAL);
PHP

  case "$server" in nginx|apache) ;; *) die "--server must be nginx or apache" ;; esac
  svc_installed httpd || [ "$server" != apache ] || die "apache backend needs httpd — bhserve install httpd"

  render_fpm_pool "$phpkey" || true
  render_site_vhost "$name" "$domain" "$root" "$phpkey" "$server"
  [ "$server" = apache ] && apache_start >/dev/null 2>&1 || true
  hdr "Site '$name' added"
  info "domain : http://$domain  (https after: bhserve secure $domain)"
  info "root   : $root"
  info "php    : $phpkey   server: $server"
  info "https  : bhserve secure $domain"
  maybe_reload_nginx
}

site_rm() {
  [ $# -ge 1 ] || die "usage: bhserve site rm <name>"
  local name="$1"
  rm -f "$BH_HOME/nginx/sites/$name.conf" "$BH_HOME/nginx/sites/$name.conf.disabled" \
        "$BH_HOME/apache/sites/$name.conf"
  ok "removed vhost for $name"
  info "(site files left on disk; remove manually if desired)"
  maybe_reload_nginx
  apache_reload
}

site_list() {
  hdr "BHServe sites"
  shopt -s nullglob
  local found=0
  for f in "$BH_HOME"/nginx/sites/*.conf; do
    found=1
    local n; n="$(basename "$f" .conf)"
    local dom; dom="$(awk '/server_name/{print $2; exit}' "$f" | tr -d ';')"
    local php; php="$(sed -n 's/.*php=\([^[:space:]]*\).*/\1/p' "$f" | head -1)"
    local sec="http"; grep -q "ssl_certificate " "$f" && sec="https"
    ok "$(printf '%-18s' "$n") ${c_dim}$dom  [$php]  $sec${c_reset}"
  done
  [ "$found" = 1 ] || info "no sites yet — bhserve site add <name>"
}

# ── DNS (*.test via dnsmasq) ────────────────────────────────────────────────
cmd_dns() {
  need_init
  local tld; tld="$(jget tld test)"
  local conf="$BH_HOME/dnsmasq.conf"
  svc_installed dnsmasq || die "dnsmasq not installed — run: bhserve install dnsmasq"
  cat > "$conf" <<DNS
# BHServe dnsmasq — resolve *.$tld to localhost
address=/.$tld/127.0.0.1
port=53
listen-address=127.0.0.1
DNS
  ok "wrote $conf"
  hdr "Privileged steps (need sudo — dnsmasq binds :53 and /etc/resolver is root-owned)"
  cat <<STEPS
  Run these to activate *.${tld} resolution:

    sudo cp "$conf" $BREW_PREFIX/etc/dnsmasq.d/bhserve.conf
    sudo brew services restart dnsmasq
    sudo mkdir -p /etc/resolver
    echo 'nameserver 127.0.0.1' | sudo tee /etc/resolver/${tld} >/dev/null

  Verify:  ping -c1 anything.${tld}   (should resolve to 127.0.0.1)
STEPS
}

# ── HTTPS (mkcert) ──────────────────────────────────────────────────────────
cmd_secure() {
  need_init
  [ $# -ge 1 ] || die "usage: bhserve secure <domain>   (e.g. myapp.test)"
  svc_installed mkcert || die "mkcert not installed — run: bhserve install mkcert"
  local mkc="$BREW_PREFIX/bin/mkcert" domain="$1"
  hdr "Provisioning trusted cert for $domain"
  if [ ! -d "$("$mkc" -CAROOT)" ] || [ ! -f "$("$mkc" -CAROOT)/rootCA.pem" ]; then
    warn "local CA not installed yet — running 'mkcert -install' (will prompt for sudo/keychain)"
    "$mkc" -install || die "mkcert -install failed"
  fi
  ( cd "$BH_HOME/certs" && "$mkc" -cert-file "$domain.pem" -key-file "$domain-key.pem" "$domain" ) \
    && ok "cert: $BH_HOME/certs/$domain.pem" || die "mkcert failed"
  # Re-render the vhost if a site for this domain exists, so the ssl block turns on.
  local name="${domain%.*}"; name="${name%%.*}"
  local conf="$BH_HOME/nginx/sites/$name.conf"
  if [ -f "$conf" ]; then
    local root php server
    root="$(awk '/^[[:space:]]*root /{print $2; exit}' "$conf" | tr -d ';')"
    php="$(sed -n 's/.*php=\([^[:space:]]*\).*/\1/p' "$conf" | head -1)"
    server="$(vhost_server "$conf")"
    render_site_vhost "$name" "$domain" "$root" "$php" "$server"
    ok "re-rendered vhost with HTTPS"
    maybe_reload_nginx
  fi
}

# ── process management ──────────────────────────────────────────────────────
NGINX_BIN(){ echo "$BREW_PREFIX/bin/nginx"; }
nginx_running(){ local p="$BH_HOME/run/nginx.pid"; [ -f "$p" ] && pid_alive "$(cat "$p")"; }
needs_root_ports(){ local h; h="$(jget http_port 80)"; [ "$h" -lt 1024 ]; }

nginx_start(){
  render_nginx_main "$(jget http_port 80)"
  local bin; bin="$(NGINX_BIN)"; [ -x "$bin" ] || die "nginx not installed — bhserve install nginx"
  if nginx_running; then ok "nginx already running (pid $(cat "$BH_HOME/run/nginx.pid"))"; return; fi
  local pre=""; needs_root_ports && pre="sudo"
  "$bin" -t -c "$BH_HOME/nginx/nginx.conf" -p "$BH_HOME/nginx" 2>/dev/null || { $bin -t -c "$BH_HOME/nginx/nginx.conf" -p "$BH_HOME/nginx"; die "nginx config test failed"; }
  $pre "$bin" -c "$BH_HOME/nginx/nginx.conf" -p "$BH_HOME/nginx" && ok "nginx started${pre:+ (sudo)}" || no "nginx failed to start"
}
# Graceful reload of the running nginx (picks up new/changed vhosts).
nginx_reload(){
  nginx_running || return 0
  local bin pre=""; bin="$(NGINX_BIN)"; needs_root_ports && pre="sudo"
  $pre "$bin" -s reload -c "$BH_HOME/nginx/nginx.conf" -p "$BH_HOME/nginx" 2>/dev/null \
    && ok "nginx reloaded" || warn "reload failed — run: bhserve restart nginx"
}
# Auto-apply config changes: reload interactively (one sudo prompt); from the GUI
# (no tty) just note it — the GUI issues its own privileged restart.
maybe_reload_nginx(){
  nginx_running || return 0
  if [ -t 1 ]; then nginx_reload; else info "reload nginx to serve changes (bhserve restart nginx)"; fi
}

nginx_stop(){
  local bin pre=""; bin="$(NGINX_BIN)"; needs_root_ports && pre="sudo"
  if nginx_running; then
    $pre "$bin" -s stop -c "$BH_HOME/nginx/nginx.conf" -p "$BH_HOME/nginx" 2>/dev/null \
      || $pre kill "$(cat "$BH_HOME/run/nginx.pid")" 2>/dev/null || true
    ok "nginx stopped"
  elif pgrep -f "nginx.*$BH_HOME/nginx/nginx.conf" >/dev/null 2>&1; then
    # pid file stale but a BHServe nginx is still bound — kill it by config path.
    warn "stale nginx (pid file out of sync) — terminating by config match"
    $pre pkill -f "nginx.*$BH_HOME/nginx/nginx.conf" && ok "nginx stopped" || no "could not stop stale nginx"
  else info "nginx not running"; fi
  rm -f "$BH_HOME/run/nginx.pid" 2>/dev/null || true
}

# Is a php pool running? (by its pid file)
fpm_running(){ local pid="$BH_HOME/run/php-$(php_label "$1").pid"; [ -f "$pid" ] && pid_alive "$(cat "$pid")"; }

# brew-services managed daemons (db/cache/mail)
brew_svc(){ # action key
  local action="$1" key="$2" formula; formula="$(svc_formula "$key")"
  svc_installed "$key" || { warn "$key not installed"; return; }
  brew services "$action" "$formula" >/dev/null 2>&1 && ok "$key $action" || no "$key $action failed"
}

# Start every installed + enabled (auto-start) service. Order follows the registry
# (PHP pools → nginx → apache → DBs), so sockets exist before nginx proxies them.
start_all(){
  hdr "Starting enabled services"
  # ensure the default PHP pool conf exists so a fresh install has something to start
  [ -n "$(fpm_keys)" ] || render_fpm_pool "$(php_key default)" >/dev/null 2>&1 || true
  local IFS='|' key formula probe role
  while read -r key formula probe role; do
    [ -n "$key" ] || continue
    svc_installed "$key" || continue
    svc_enabled "$key" || continue
    case "$role" in
      php) fpm_start "$key" ;;
      web) [ "$key" = nginx ] && nginx_start; [ "$key" = httpd ] && apache_start ;;
      db|cache|mail) brew_svc start "$key" ;;
    esac
  done < <(services)
  # bring Apache up if any site uses it, even when httpd isn't in the enabled set
  have_apache_sites && apache_start >/dev/null 2>&1 || true
}
# Stop everything that's running (web + all PHP pools + DB/cache/mail daemons).
stop_all(){
  hdr "Stopping all services"
  nginx_stop
  apache_running && apache_stop || true
  local k; for k in $(fpm_keys); do fpm_stop "$k"; done
  local IFS='|' key formula probe role
  while read -r key formula probe role; do
    [ -n "$key" ] || continue
    case "$role" in db|cache|mail) svc_installed "$key" && brew_svc stop "$key" >/dev/null 2>&1 || true ;; esac
  done < <(services)
  ok "all services stopped"
}

cmd_start() {
  need_init
  local what="${1:-all}"
  case "$what" in
    all) start_all ;;
    nginx) nginx_start ;;
    apache|httpd) apache_start ;;
    php|php@*) fpm_start "$(php_key "$what")" ;;
    php*) fpm_start "$(php_key "${what#php}")" ;;
    mariadb|mysql|postgresql@17|redis|memcached|mailpit|dnsmasq) brew_svc start "$what" ;;
    *) die "start: unknown target $what" ;;
  esac
}
cmd_stop() {
  need_init
  local what="${1:-all}"
  case "$what" in
    all) stop_all ;;
    nginx) nginx_stop ;;
    apache|httpd) apache_stop ;;
    php|php@*) fpm_stop "$(php_key "$what")" ;;
    php*) fpm_stop "$(php_key "${what#php}")" ;;
    mariadb|mysql|postgresql@17|redis|memcached|mailpit|dnsmasq) brew_svc stop "$what" ;;
    *) die "stop: unknown target $what" ;;
  esac
}
cmd_restart() {
  need_init
  local what="${1:-all}"
  cmd_stop "$what"; cmd_start "$what"
}

# ── databases (mysql/mariadb + postgresql) ──────────────────────────────────
MYSQL_CLI(){ echo "$BREW_PREFIX/bin/mysql"; }
PSQL_CLI(){ echo "$BREW_PREFIX/opt/postgresql@17/bin/psql"; }
PG_BIN(){ echo "$BREW_PREFIX/opt/postgresql@17/bin/$1"; }

db_valid_name(){ [[ "$1" =~ ^[A-Za-z0-9_]+$ ]] || die "invalid db name '$1' (use letters, digits, underscore)"; }

# Run the mysql client with auto-detected auth: OS user first (brew MariaDB's
# unix_socket account), then passwordless -u root (Oracle MySQL / older setups).
mysql_run(){
  local c; c="$(MYSQL_CLI)"; [ -x "$c" ] || return 127
  if "$c" -N -e "SELECT 1;" >/dev/null 2>&1; then "$c" "$@"
  elif "$c" -u root -N -e "SELECT 1;" >/dev/null 2>&1; then "$c" -u root "$@"
  else return 1; fi
}

# list user databases for an engine, one per line
db_names_mysql(){
  mysql_run -N -e "SHOW DATABASES;" 2>/dev/null \
    | grep -vE '^(information_schema|performance_schema|mysql|sys)$' || true; }
db_names_pg(){ local c; c="$(PSQL_CLI)"; [ -x "$c" ] || return 0
  "$c" -U "$USER_NAME" -d postgres -tAc \
    "SELECT datname FROM pg_database WHERE datistemplate=false AND datname<>'postgres';" 2>/dev/null || true; }

# The convention: each managed DB optionally has a dedicated user named after the
# DB at @localhost. "Has a password" == that user exists.
db_users_mysql(){ mysql_run -N -e "SELECT user FROM mysql.user WHERE host='localhost';" 2>/dev/null || true; }

# Escape a string for a MySQL single-quoted literal.
mysql_esc(){ local s="$1"; s="${s//\\/\\\\}"; s="${s//\'/\\\'}"; printf '%s' "$s"; }

# Password comes from --password OR $BHSERVE_DB_PASSWORD (env keeps it out of `ps`).
DB_PASSWORD=""

cmd_db(){
  need_init
  local sub="${1:-list}"; shift || true
  local engine=mysql json=0 name="" pw_set=0
  while [ $# -gt 0 ]; do case "$1" in
    --engine) engine="$2"; shift 2;;
    --json) json=1; shift;;
    --password) DB_PASSWORD="$2"; pw_set=1; shift 2;;
    *) name="$1"; shift;;
  esac; done
  [ "$pw_set" = 1 ] || DB_PASSWORD="${BHSERVE_DB_PASSWORD:-}"
  case "$sub" in
    list) db_list "$json" ;;
    create) [ -n "$name" ] || die "usage: bhserve db create <name> [--engine mysql|pg] [--password PW]"; db_create "$engine" "$name" ;;
    drop)   [ -n "$name" ] || die "usage: bhserve db drop <name> [--engine mysql|pg]"; db_drop "$engine" "$name" ;;
    passwd) [ -n "$name" ] || die "usage: bhserve db passwd <name> [--engine mysql|pg] --password PW"; db_set_password "$engine" "$name" ;;
    root-status) db_root_status ;;
    root-passwd) db_root_passwd ;;
    *) die "usage: bhserve db {list|create|drop|passwd|root-status|root-passwd} [name] [--engine mysql|pg] [--password PW]" ;;
  esac
}

# Whether mysql/mariadb root@localhost has a password set. Prints set|blank|unavailable.
db_root_status(){
  local r
  r="$(mysql_run -N -e "SELECT IF(LENGTH(authentication_string)>0,'set','blank') FROM mysql.user WHERE user='root' AND host='localhost' LIMIT 1;" 2>/dev/null)" || true
  [ -n "$r" ] && printf '%s\n' "$r" || echo unavailable
}

# Set (or, with empty password, clear) the mysql/mariadb root@localhost password.
# Only touches root — the OS-user socket account we operate through is untouched.
db_root_passwd(){
  local epw; epw="$(mysql_esc "$DB_PASSWORD")"
  mysql_run -e "ALTER USER 'root'@'localhost' IDENTIFIED BY '$epw'; FLUSH PRIVILEGES;" \
    && ok "root password $([ -n "$DB_PASSWORD" ] && echo set || echo cleared (blank))" \
    || die "failed (server running? do you have privilege?)"
}

db_list(){
  local json="$1"
  if [ "$json" = 1 ]; then
    local out="" first=1 d users=""
    users="$(db_users_mysql)"
    while read -r d; do [ -z "$d" ] && continue
      local has=false
      printf '%s\n' "$users" | grep -qx "$d" && has=true
      local row; row="$(printf '{"name":"%s","engine":"mysql","hasUser":%s,"user":"%s"}' \
        "$(json_esc "$d")" "$has" "$(json_esc "$d")")"
      [ "$first" = 1 ] && { out="$row"; first=0; } || out="$out,$row"
    done < <(db_names_mysql)
    while read -r d; do [ -z "$d" ] && continue
      local row; row="$(printf '{"name":"%s","engine":"pg","hasUser":false,"user":""}' "$(json_esc "$d")")"
      [ "$first" = 1 ] && { out="$row"; first=0; } || out="$out,$row"
    done < <(db_names_pg)
    printf '[%s]\n' "$out"
    return
  fi
  hdr "MySQL/MariaDB databases"; db_names_mysql | while read -r d; do ok "$d"; done
  hdr "PostgreSQL databases";   db_names_pg    | while read -r d; do ok "$d"; done
}

# Create user <name>@localhost with the current DB_PASSWORD and grant it the db.
mysql_grant_user(){
  local name="$1" epw; epw="$(mysql_esc "$DB_PASSWORD")"
  mysql_run -e "CREATE USER IF NOT EXISTS '$(mysql_esc "$name")'@'localhost' IDENTIFIED BY '$epw';
                ALTER USER '$(mysql_esc "$name")'@'localhost' IDENTIFIED BY '$epw';
                GRANT ALL PRIVILEGES ON \`$name\`.* TO '$(mysql_esc "$name")'@'localhost';
                FLUSH PRIVILEGES;"
}

db_create(){
  local engine="$1" name="$2"; db_valid_name "$name"
  case "$engine" in
    mysql|mariadb)
      mysql_run -e "CREATE DATABASE IF NOT EXISTS \`$name\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;" \
        || die "create failed (is the server running?)"
      ok "created mysql db '$name'"
      if [ -n "$DB_PASSWORD" ]; then
        mysql_grant_user "$name" && ok "user '$name'@localhost created with password" || die "user/grant failed"
      fi ;;
    pg|postgres) local c; c="$(PG_BIN createdb)"; [ -x "$c" ] || die "postgresql not installed"
      "$c" -U "$USER_NAME" "$name" || die "create failed (is the server running?)"
      ok "created postgres db '$name'"
      if [ -n "$DB_PASSWORD" ]; then
        "$(PSQL_CLI)" -U "$USER_NAME" -d postgres -c \
          "DO \$\$ BEGIN CREATE ROLE \"$name\" LOGIN PASSWORD '$(mysql_esc "$DB_PASSWORD")'; EXCEPTION WHEN duplicate_object THEN ALTER ROLE \"$name\" PASSWORD '$(mysql_esc "$DB_PASSWORD")'; END \$\$; GRANT ALL PRIVILEGES ON DATABASE \"$name\" TO \"$name\";" \
          && ok "role '$name' created with password" || warn "role/grant failed"
      fi ;;
    *) die "unknown engine: $engine (mysql|pg)" ;;
  esac
}

# Set or change the password for a db's user (creates the user+grant if missing).
db_set_password(){
  local engine="$1" name="$2"; db_valid_name "$name"
  [ -n "$DB_PASSWORD" ] || die "no password given (--password or \$BHSERVE_DB_PASSWORD)"
  case "$engine" in
    mysql|mariadb)
      mysql_grant_user "$name" && ok "password set for '$name'@localhost" || die "set password failed (is the server running?)" ;;
    pg|postgres) local c; c="$(PSQL_CLI)"; [ -x "$c" ] || die "postgresql not installed"
      "$c" -U "$USER_NAME" -d postgres -c \
        "DO \$\$ BEGIN CREATE ROLE \"$name\" LOGIN PASSWORD '$(mysql_esc "$DB_PASSWORD")'; EXCEPTION WHEN duplicate_object THEN ALTER ROLE \"$name\" PASSWORD '$(mysql_esc "$DB_PASSWORD")'; END \$\$; GRANT ALL PRIVILEGES ON DATABASE \"$name\" TO \"$name\";" \
        && ok "password set for role '$name'" || die "set password failed" ;;
    *) die "unknown engine: $engine (mysql|pg)" ;;
  esac
}

db_drop(){
  local engine="$1" name="$2"; db_valid_name "$name"
  case "$engine" in
    mysql|mariadb)
      mysql_run -e "DROP DATABASE IF EXISTS \`$name\`; DROP USER IF EXISTS '$(mysql_esc "$name")'@'localhost';" \
        && ok "dropped mysql db '$name' (and its user, if any)" || die "drop failed (is the server running?)" ;;
    pg|postgres) local c; c="$(PG_BIN dropdb)"; [ -x "$c" ] || die "postgresql not installed"
      "$c" -U "$USER_NAME" "$name" && ok "dropped postgres db '$name'" || die "drop failed (is the server running?)" ;;
    *) die "unknown engine: $engine (mysql|pg)" ;;
  esac
}

# ── privileged helper (password-less nginx control + autostart) ──────────────
# A sudoers rule so the GUI/CLI can start/stop/reload nginx (binds :80/:443)
# without a password prompt — the standard local-dev approach (à la Valet).
SUDOERS_FILE="/etc/sudoers.d/bhserve"
helper_installed(){ [ -f "$SUDOERS_FILE" ]; }
helper_target_user(){ echo "${SUDO_USER:-$(stat -f%Su /dev/console 2>/dev/null)}"; }

cmd_helper(){
  need_init
  case "${1:-status}" in
    install)   helper_install ;;
    uninstall) helper_uninstall ;;
    status)    helper_installed && ok "privileged helper: installed" || info "privileged helper: not installed" ;;
    *) die "usage: bhserve helper {install|uninstall|status}" ;;
  esac
}

helper_install(){
  [ "$(id -u)" = 0 ] || die "needs root: sudo bhserve helper install   (or use the GUI button)"
  local u nginx tmp; u="$(helper_target_user)"; nginx="$BREW_PREFIX/bin/nginx"
  [ -n "$u" ] || die "could not determine the login user"
  tmp="$(mktemp)"
  cat > "$tmp" <<SUDO
# BHServe — let $u control nginx (binds :80/:443) without a password.
# Remove with: sudo bhserve helper uninstall
Defaults:$u !requiretty
$u ALL=(root) NOPASSWD: $nginx
SUDO
  /usr/sbin/visudo -cf "$tmp" >/dev/null 2>&1 || { rm -f "$tmp"; die "sudoers validation failed — not installed"; }
  install -m 0440 -o root -g wheel "$tmp" "$SUDOERS_FILE"; rm -f "$tmp"
  ok "privileged helper installed — nginx start/stop/reload no longer needs a password"
  info "with this + 'Launch at login' + autostart, BHServe comes up after reboot with no prompt"
}

helper_uninstall(){
  [ "$(id -u)" = 0 ] || die "needs root: sudo bhserve helper uninstall"
  rm -f "$SUDOERS_FILE" && ok "privileged helper removed" || die "remove failed"
}

# ── config (editable settings) ───────────────────────────────────────────────
cmd_config(){
  need_init
  local sub="${1:-show}"; shift || true
  case "$sub" in
    show) cat "$BH_HOME/config/bhserve.json" ;;
    set)  config_set "$@" ;;
    *) die "usage: bhserve config {show|set <key> <value>}" ;;
  esac
}

# Rewrite bhserve.json from current values, overriding one key.
json_set(){
  local k="$1" v="$2"
  local tld httpp httpsp dphp dweb bp sroot autostart
  tld="$(jget tld test)"; httpp="$(jget http_port 80)"; httpsp="$(jget https_port 443)"
  dphp="$(jget default_php 8.4)"; dweb="$(jget default_web nginx)"
  bp="$(jget brew_prefix "$BREW_PREFIX")"; sroot="$(jget sites_root "$HOME/Sites")"
  autostart="$(jget autostart false)"
  case "$k" in
    tld) tld="$v";; http_port) httpp="$v";; https_port) httpsp="$v";;
    default_php) dphp="$v";; default_web) dweb="$v";; sites_root) sroot="$v";; autostart) autostart="$v";;
  esac
  cat > "$BH_HOME/config/bhserve.json" <<JSON
{
  "tld": "$tld",
  "http_port": $httpp,
  "https_port": $httpsp,
  "default_php": "$dphp",
  "default_web": "$dweb",
  "brew_prefix": "$bp",
  "sites_root": "$sroot",
  "autostart": $autostart
}
JSON
}

# Re-render every site vhost (e.g. after a TLD/port change).
regen_all_vhosts(){
  shopt -s nullglob
  local tld; tld="$(jget tld test)"
  local f n root php server
  for f in "$BH_HOME"/nginx/sites/*.conf; do
    n="$(basename "$f" .conf)"
    root="$(awk '/^[[:space:]]*root /{print $2; exit}' "$f" | tr -d ';')"
    php="$(sed -n 's/.*php=\([^[:space:]]*\).*/\1/p' "$f" | head -1)"
    server="$(vhost_server "$f")"
    render_site_vhost "$n" "$n.$tld" "$root" "$php" "$server"
  done
  apache_reload
}

config_set(){
  [ $# -ge 2 ] || die "usage: bhserve config set <key> <value>"
  local key="$1" val="$2"
  case "$key" in
    http_port|https_port) [[ "$val" =~ ^[0-9]+$ ]] || die "$key must be numeric" ;;
    tld) [[ "$val" =~ ^[a-z][a-z0-9-]*$ ]] || die "tld must be lowercase letters/digits/hyphen" ;;
    sites_root) [ -n "$val" ] || die "sites_root cannot be empty" ;;
    default_php) val="$(php_key "$val")" ;;
    default_web) [[ "$val" =~ ^(nginx|apache)$ ]] || die "default_web must be nginx|apache" ;;
    autostart) [[ "$val" =~ ^(true|false)$ ]] || die "autostart must be true|false" ;;
    *) die "unknown/uneditable key: $key" ;;
  esac
  json_set "$key" "$val"
  ok "set $key = $val"
  case "$key" in
    http_port|https_port|tld)
      regen_all_vhosts
      render_nginx_main "$(jget http_port 80)"
      warn "restart nginx to apply (bhserve restart nginx)"
      [ "$key" = tld ] && warn "TLD changed — HTTPS certs are per-domain; re-run 'bhserve secure <name>.$val' per site" ;;
  esac
}

# ── logs ─────────────────────────────────────────────────────────────────────
cmd_logs(){
  need_init
  if [ "${1:-}" = "--list" ]; then
    local out="" first=1 f b
    shopt -s nullglob
    for f in "$BH_HOME"/logs/*.log; do
      b="$(basename "$f")"
      [ "$first" = 1 ] && { out="\"$b\""; first=0; } || out="$out,\"$b\""
    done
    printf '[%s]\n' "$out"; return
  fi
  local name="${1:-nginx-error.log}" n="${2:-200}"
  local f="$BH_HOME/logs/$name"
  [ -f "$f" ] || { echo "(no log yet: $name)"; return; }
  tail -n "$n" "$f"
}

# ── node (multi-version via fnm; versions live under ~/.bhserve/fnm) ─────────
FNM_BIN(){ echo "$BREW_PREFIX/bin/fnm"; }
fnm_run(){
  local f; f="$(FNM_BIN)"; [ -x "$f" ] || die "fnm not installed — bhserve install fnm"
  export FNM_DIR="$BH_HOME/fnm"; mkdir -p "$FNM_DIR"
  "$f" --fnm-dir "$FNM_DIR" "$@"
}

cmd_node(){
  need_init
  local sub="${1:-list}"; shift || true
  case "$sub" in
    list)  node_list "${1:-}" ;;
    remote) fnm_run list-remote --lts 2>/dev/null | tail -40 ;;
    install|i)  [ -n "${1:-}" ] || die "usage: bhserve node install <version>"
                hdr "Installing Node $1"; fnm_run install "$1" && ok "node $1 installed" || die "install failed" ;;
    use|default) [ -n "${1:-}" ] || die "usage: bhserve node use <version>"; node_use "$1" ;;
    uninstall|rm|uni) [ -n "${1:-}" ] || die "usage: bhserve node uninstall <version>"
                fnm_run uninstall "$1" && ok "node $1 uninstalled" || die "uninstall failed" ;;
    *) die "usage: bhserve node {list|remote|install|use|uninstall} [version]" ;;
  esac
}

node_list(){
  local json="$1" out; out="$(fnm_run list 2>/dev/null || true)"
  if [ "$json" = "--json" ]; then
    local arr="" first=1 line v def
    while IFS= read -r line; do
      [ -z "$line" ] && continue
      v="$(printf '%s' "$line" | grep -oE 'v[0-9]+\.[0-9]+\.[0-9]+' | head -1 || true)"
      [ -z "$v" ] && continue
      def=false; printf '%s' "$line" | grep -q 'default' && def=true
      local row; row="$(printf '{"version":"%s","default":%s}' "$v" "$def")"
      [ "$first" = 1 ] && { arr="$row"; first=0; } || arr="$arr,$row"
    done <<< "$out"
    printf '[%s]\n' "$arr"
    return
  fi
  hdr "Installed Node versions"; printf '%s\n' "$out"
}

# Set the default node + link node/npm/npx into ~/.bhserve/bin for PATH use.
node_use(){
  local ver="$1" path bindir b
  fnm_run default "$ver" || die "set default failed (is $ver installed?)"
  path="$(fnm_run exec --using="$ver" -- node -e 'console.log(process.execPath)' 2>/dev/null | tail -1)"
  [ -n "$path" ] || die "could not resolve node $ver"
  bindir="$(dirname "$path")"
  mkdir -p "$BH_HOME/bin"
  for b in node npm npx corepack; do [ -e "$bindir/$b" ] && ln -sf "$bindir/$b" "$BH_HOME/bin/$b"; done
  ok "default node = $ver"
  info "linked node/npm/npx into $BH_HOME/bin — add to PATH: export PATH=\"$BH_HOME/bin:\$PATH\""
}

# ── php (ionCube loader + per-version config) ────────────────────────────────
IONCUBE_URL_ARM="https://downloads.ioncube.com/loader_downloads/ioncube_loaders_dar_arm.zip"
IONCUBE_URL_X64="https://downloads.ioncube.com/loader_downloads/ioncube_loaders_dar_x86-64.zip"

cmd_php(){
  need_init
  local sub="${1:-status}"; shift || true
  case "$sub" in
    ioncube) php_ioncube "$@" ;;
    status)  php_status ;;
    *) die "usage: bhserve php {ioncube [version|all]|status}" ;;
  esac
}

# Major.minor of a php key's binary (e.g. 8.4), used for the loader filename.
php_mm(){
  local key="$1" b; b="$(php_fpm_bin "$key")"; b="${b%/sbin/php-fpm}/bin/php"
  [ -x "$b" ] || b="$BREW_PREFIX/bin/php"
  "$b" -r 'echo PHP_MAJOR_VERSION.".".PHP_MINOR_VERSION;' 2>/dev/null || true
}

php_ioncube(){
  local target="${1:-all}"
  local dir="$BH_HOME/ioncube"
  # download + extract the loader bundle once (arm64 first, x86-64 fallback)
  if [ ! -d "$dir/ioncube" ]; then
    mkdir -p "$dir"; hdr "Downloading ionCube loaders"
    local url="$IONCUBE_URL_ARM"; [ "$(uname -m)" = x86_64 ] && url="$IONCUBE_URL_X64"
    curl -fsSL "$url" -o "$dir/loaders.zip" || die "download failed ($url)"
    ( cd "$dir" && unzip -oq loaders.zip ) || die "unzip failed"
    ok "loaders in $dir/ioncube"
  fi
  # configure each installed php (or one)
  local IFS='|' key formula probe role
  while read -r key formula probe role; do
    [ "$role" = php ] || continue
    svc_installed "$key" || continue
    [ "$target" = all ] || [ "$target" = "$key" ] || [ "$target" = "$(php_label "$key")" ] || continue
    local mm so cd_dir; mm="$(php_mm "$key")"
    so="$dir/ioncube/ioncube_loader_dar_$mm.so"
    if [ ! -f "$so" ]; then warn "$key: ionCube has no macOS loader for PHP $mm yet (mac = 7.4 & 8.1 only; Linux-ARM loaders are ELF, won't load here). WHMCS/Blesta run on 8.1, which works."; continue; fi
    cd_dir="$BH_HOME/php/conf.d/$(php_label "$key")"; mkdir -p "$cd_dir"
    printf 'zend_extension=%s\n' "$so" > "$cd_dir/00-ioncube.ini"
    ok "ionCube configured for $key (PHP $mm)"
  done < <(services)
  info "restart PHP-FPM to load it: bhserve restart all  (verify: bhserve php status)"
}

php_status(){
  local IFS='|' key formula probe role
  hdr "PHP versions"
  while read -r key formula probe role; do
    [ "$role" = php ] || continue
    svc_installed "$key" || continue
    local b="${BREW_PREFIX}/${probe}" ic="no" cd_dir
    cd_dir="$BH_HOME/php/conf.d/$(php_label "$key")"
    [ -f "$cd_dir/00-ioncube.ini" ] && ic="yes"
    if PHP_INI_SCAN_DIR=":$cd_dir" "$b" -v 2>/dev/null | grep -qi ioncube; then ic="loaded"; fi
    ok "$(printf '%-10s' "$key") PHP $(php_mm "$key")   ionCube: $ic"
  done < <(services)
}

# ── phpMyAdmin ───────────────────────────────────────────────────────────────
PMA_VER="5.2.3"

pma_socket(){
  local s; s="$(mysql_run -N -e "SHOW VARIABLES LIKE 'socket';" 2>/dev/null | awk '{print $2}')"
  [ -n "$s" ] && { echo "$s"; return; }
  local c
  for c in /tmp/mysql.sock "$BREW_PREFIX/var/run/mariadb.sock" /tmp/mariadb.sock; do
    [ -S "$c" ] && { echo "$c"; return; }
  done
  echo /tmp/mysql.sock
}

cmd_pma(){
  need_init
  local sub="${1:-install}"; shift || true
  case "$sub" in
    install) pma_install ;;
    *) die "usage: bhserve pma install" ;;
  esac
}

pma_install(){
  local apps="$BH_HOME/apps" dir="$BH_HOME/apps/phpmyadmin"
  mkdir -p "$apps"
  if [ ! -f "$dir/index.php" ]; then
    hdr "Downloading phpMyAdmin $PMA_VER"
    curl -fsSL "https://files.phpmyadmin.net/phpMyAdmin/$PMA_VER/phpMyAdmin-$PMA_VER-all-languages.zip" -o "$apps/pma.zip" || die "download failed"
    ( cd "$apps" && unzip -oq pma.zip && rm -rf phpmyadmin && mv "phpMyAdmin-$PMA_VER-all-languages" phpmyadmin && rm -f pma.zip ) || die "extract failed"
    ok "phpMyAdmin in $dir"
  else
    ok "phpMyAdmin already present ($dir)"
  fi
  mkdir -p "$dir/tmp"
  local secret sock; secret="$(openssl rand -hex 16)"; sock="$(pma_socket)"
  cat > "$dir/config.inc.php" <<PHP
<?php
// Generated by BHServe. Logs in over the MariaDB socket; the FPM pool runs as
// the OS user, so its passwordless socket account works (AllowNoPassword).
\$cfg['blowfish_secret'] = '$secret';
\$i = 0; \$i++;
\$cfg['Servers'][\$i]['auth_type']      = 'cookie';
\$cfg['Servers'][\$i]['host']           = 'localhost';
\$cfg['Servers'][\$i]['socket']         = '$sock';
\$cfg['Servers'][\$i]['compress']       = false;
\$cfg['Servers'][\$i]['AllowNoPassword'] = true;
\$cfg['TempDir'] = '$dir/tmp';
PHP
  ok "wrote config.inc.php (socket: $sock)"
  local tld phpkey; tld="$(jget tld test)"; phpkey="$(php_key default)"
  render_fpm_pool "$phpkey" >/dev/null 2>&1 || true
  render_site_vhost "phpmyadmin" "phpmyadmin.$tld" "$dir" "$phpkey"
  hdr "phpMyAdmin ready"
  info "URL  : http://phpmyadmin.$tld   (HTTPS: bhserve secure phpmyadmin.$tld)"
  info "login: your DB user (e.g. '$USER_NAME' with a blank password, or 'root' if you set one)"
  info "uploads allowed up to 2GB"
  maybe_reload_nginx
}

# ── Adminer (single-file DB admin) ───────────────────────────────────────────
cmd_adminer(){ need_init; case "${1:-install}" in install) adminer_install ;; *) die "usage: bhserve adminer install" ;; esac; }
adminer_install(){
  local dir="$BH_HOME/apps/adminer"; mkdir -p "$dir"
  if [ ! -f "$dir/index.php" ]; then
    hdr "Downloading Adminer"
    curl -fsSL "https://www.adminer.org/latest.php" -o "$dir/index.php" || die "download failed"
    ok "Adminer in $dir"
  else ok "Adminer already present ($dir)"; fi
  local tld phpkey; tld="$(jget tld test)"; phpkey="$(php_key default)"
  render_fpm_pool "$phpkey" >/dev/null 2>&1 || true
  render_site_vhost adminer "adminer.$tld" "$dir" "$phpkey" nginx
  hdr "Adminer ready"
  info "URL  : http://adminer.$tld"
  info "login: System=MySQL, Server=localhost, Username=$USER_NAME (blank pass) or root"
